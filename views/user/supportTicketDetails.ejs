<%- contentFor('body') %>

<div class="min-h-[80vh] py-12 px-4 md:px-8 bg-black">
    <div class="max-w-4xl mx-auto space-y-10">
        <!-- Ticket Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 pb-8 border-b border-white/5">
            <div class="space-y-4">
                <a href="/support" class="inline-flex items-center gap-2 text-white/30 hover:text-white text-[10px] font-black uppercase tracking-widest transition-colors mb-4">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    Back to Communication Logs
                </a>
                <div class="flex items-center gap-4">
                    <span class="text-xs font-mono text-accent font-bold tracking-widest uppercase"><%= ticket.ticketId %></span>
                    <div class="px-3 py-1 rounded-sm text-[8px] font-black uppercase tracking-[0.2em] 
                        <%= ticket.status === 'Open' ? 'bg-accent/10 text-accent border border-accent/20' : 
                            ticket.status === 'In-Progress' ? 'bg-status-success/10 text-status-success border border-status-success/20' :
                            ticket.status === 'Resolved' ? 'bg-white/10 text-white border border-white/20' :
                            'bg-white/5 text-white/40 border border-white/10' %>">
                        <%= ticket.status %>
                    </div>
                </div>
                <h1 class="text-4xl font-black text-white uppercase tracking-tight"><%= ticket.subject %></h1>
                <p class="text-white/40 text-[9px] font-bold uppercase tracking-widest">Category: <span class="text-white"><%= ticket.category %></span> • Created: <span class="text-white"><%= new Date(ticket.createdAt).toLocaleString() %></span></p>
            </div>
        </div>

        <!-- Chat/Thread Area -->
        <div class="space-y-8 py-8">
            <!-- Initial Message -->
            <div class="flex gap-6">
                <div class="flex-shrink-0 w-12 h-12 bg-white/5 border border-white/10 rounded-full flex items-center justify-center">
                    <img src="<%= user.profileImage || '/images/default-avatar.png' %>" class="w-full h-full rounded-full object-cover">
                </div>
                <div class="flex-1 space-y-2">
                    <div class="flex items-center gap-3">
                        <span class="text-[10px] font-black text-white uppercase tracking-widest"><%= user.name %></span>
                        <span class="text-[8px] text-white/20 uppercase tracking-widest font-bold">Request Origin</span>
                    </div>
                    <div class="bg-[#0a0a0a] border border-white/5 p-6 rounded-sm text-white/70 text-sm leading-relaxed">
                        <%= ticket.message %>
                    </div>
                    <% if (ticket.orderId) { %>
                        <div class="mt-4 p-4 bg-white/[0.02] border border-white/5 inline-flex items-center gap-4">
                            <span class="text-[9px] text-white/30 font-bold uppercase tracking-widest">Linked Order</span>
                            <span class="text-accent font-mono text-[10px] font-bold"><%= ticket.orderId %></span>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Responses -->
            <% ticket.responses.forEach(response => { %>
                <div class="flex gap-6 <%= response.isAdmin ? 'flex-row-reverse' : '' %>">
                    <div class="flex-shrink-0 w-12 h-12 bg-white/5 border border-white/10 rounded-full flex items-center justify-center overflow-hidden">
                        <% if (response.isAdmin) { %>
                            <div class="w-full h-full bg-accent flex items-center justify-center text-black font-black text-xs">ST</div>
                        <% } else { %>
                            <img src="<%= response.sender.profileImage || '/images/default-avatar.png' %>" class="w-full h-full object-cover">
                        <% } %>
                    </div>
                    <div class="flex-1 space-y-2 <%= response.isAdmin ? 'text-right' : '' %>">
                        <div class="flex items-center gap-3 <%= response.isAdmin ? 'justify-end' : '' %>">
                            <span class="text-[10px] font-black <%= response.isAdmin ? 'text-accent' : 'text-white' %> uppercase tracking-widest">
                                <%= response.isAdmin ? 'Starzo Technician' : response.sender.name %>
                            </span>
                            <span class="text-[8px] text-white/20 uppercase tracking-widest font-bold">
                                <%= new Date(response.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                            </span>
                        </div>
                        <div class="bg-[#0a0a0a] border <%= response.isAdmin ? 'border-accent/20' : 'border-white/5' %> p-6 rounded-sm text-white/70 text-sm leading-relaxed inline-block text-left max-w-[85%]">
                            <%= response.message %>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>

        <!-- Reply Area -->
        <% if (ticket.status !== 'Closed') { %>
            <div x-data="ticketReplier" class="pt-12 border-t border-white/5">
                <form @submit.prevent="submitReply" class="space-y-6">
                    <div class="space-y-2">
                        <label class="text-[9px] font-black uppercase tracking-widest text-white/30">Append Message to Protocol</label>
                        <textarea x-model="message" rows="4" placeholder="Type your response here..."
                            class="w-full bg-black border border-white/10 p-6 text-white text-sm focus:outline-none focus:border-accent transition-colors resize-none"></textarea>
                    </div>
                    <div class="flex justify-end">
                        <button type="submit" :disabled="isSubmitting || !message"
                            class="px-10 py-4 bg-white text-black font-black text-[10px] tracking-widest uppercase hover:bg-accent transition-all disabled:opacity-50 btn-press">
                            <span x-show="!isSubmitting">Send Response</span>
                            <span x-show="isSubmitting">Transmitting...</span>
                        </button>
                    </div>
                </form>
            </div>
        <% } else { %>
            <div class="pt-12 border-t border-white/5 text-center">
                <p class="text-white/20 text-[10px] font-black uppercase tracking-[0.3em]">This communication channel has been terminated.</p>
            </div>
        <% } %>
    </div>
</div>

<script>
    (() => {
        const register = () => {
            if (Alpine.data('ticketReplier')) return;
            Alpine.data('ticketReplier', () => ({
                message: '',
                isSubmitting: false,
                async submitReply() {
                    if (!this.message) return;
                    this.isSubmitting = true;
                    try {
                        const res = await fetch('/support/ticket/<%= ticket._id %>/reply', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ message: this.message })
                        });
                        const data = await res.json();
                        if (data.success) {
                            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: data.message, type: 'success' } }));
                            setTimeout(() => window.location.reload(), 1000);
                        } else {
                            throw new Error(data.message);
                        }
                    } catch (error) {
                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: error.message || "Failed to send reply.", type: 'error' } }));
                    } finally {
                        this.isSubmitting = false;
                    }
                }
            }));
        };

        if (window.Alpine) register();
        else document.addEventListener('alpine:init', register);
    })();
</script>
