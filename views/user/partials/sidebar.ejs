
  <!-- ╔══════════════ SIDEBAR ══════════════╗ -->
      <aside class="sidebar">
        <style>

            .sidebar {
                background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      position: sticky;
      top: calc(var(--nav-h) + 24px);
    }

    .sidebar-nav {
      padding: 8px 0;
      display: flex;
      flex-direction: column;
    }

    .sidebar-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 11px 18px;
      font-size: 13.5px;
      font-weight: 500;
      color: var(--text-400);
      border-radius: 0;
      cursor: pointer;
      transition: background .15s, color .15s;
      position: relative;
    }

    .sidebar-item:hover {
      background: var(--bg-subtle);
      color: var(--text-900);
    }

    .sidebar-item.active {
      color: var(--brand);
      background: var(--brand-light);
      font-weight: 600;
    }
    
    .sidebar-item.active::before {
        content: '';
        position: absolute;
        left: 0;
      top: 6px;
      bottom: 6px;
      width: 3px;
      background: var(--brand);
      border-radius: 0 3px 3px 0;
    }

    .sidebar-item .material-icons-round {
      font-size: 18px;
      flex-shrink: 0;
    }

    .sidebar-divider {
        height: 1px;
        background: var(--border);
      margin: 6px 14px;
    }

    .sidebar-item.danger {
      color: var(--red);
      margin: 2px 0;
    }

    .sidebar-item.danger:hover {
      background: rgba(244,63,94,.06);
    } 

    @media (max-width: 768px) {
      .sidebar {
        position: static;
        top: auto;
      }

      .sidebar-nav {
        flex-direction: row;
        overflow-x: auto;
        padding: 6px;
        gap: 6px;
      }

      .sidebar-item {
        white-space: nowrap;
        border-radius: 10px;
        padding: 9px 12px;
      }

      .sidebar-item.active::before {
        display: none;
      }

      .sidebar-divider {
        display: none;
      }
    }

    

    </style>

    <nav class="sidebar-nav">

          <a href="/profile" class="sidebar-item <%= currentPath === '/profile' ? 'active' : '' %>">
            <span class="material-icons-round">person</span>
            Profile
          </a>

          <!-- the following items are controlled by JS tabs; include hrefs for accessibility -->
          <a href="/address" class="sidebar-item <%= currentPath === '/address' ? 'active' : '' %>" onclick="showTab(this)">
            <span class="material-icons-round">location_on</span>
            Address
          </a>

          <a href="#" class="sidebar-item <%= currentPath === '/orders' ? 'active' : '' %>" onclick="showTab(this)">
            <span class="material-icons-round">shopping_bag</span>
            My Orders
          </a>

          <a href="#" class="sidebar-item <%= currentPath === '/wishlist' ? 'active' : '' %>" onclick="showTab(this)">
            <span class="material-icons-round">favorite_border</span>
            Wishlist
          </a>

          <a href="#" class="sidebar-item <%= currentPath === '/wallet' ? 'active' : '' %>" onclick="showTab(this)">
            <span class="material-icons-round" >account_balance_wallet</span>
            Wallet
          </a>

          <a href="#" class="sidebar-item <%= currentPath === '/referrals' ? 'active' : '' %>" onclick="showTab(this)">
            <span class="material-icons-round">card_giftcard</span>
            Referrals
          </a>

          <div class="sidebar-divider"></div>

     <div class="sidebar-item danger" onclick="confirmLogout()" style="cursor:pointer;">
  <span class="material-icons-round">logout</span>
  Logout
</div>

        </nav>
      </aside>
      <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
      <script>
        function confirmLogout() {  
            Swal.fire({
                title: 'Are you sure you want to logout?',
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#3085d6',
          cancelButtonColor: '#d33',
          confirmButtonText: 'Yes, logout!'
        }).then((result) => {
          if (result.isConfirmed) {
            window.location.href = '/logout';
          }
        });
    }
      </script>
