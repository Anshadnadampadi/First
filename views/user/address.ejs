  <!-- ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ TOAST ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ -->
  <div class="toast success" id="toast"></div>

  <script>
    let addresses = <%- JSON.stringify(user?.addresses || []) %>;
    let editId = null;
    let deleteId = null;

    const fieldMap = {
      type: 'f-type',
      name: 'f-name',
      phone: 'f-phone',
      addr1: 'f-addr1',
      addr2: 'f-addr2',
      city: 'f-city',
      state: 'f-state',
      zip: 'f-zip',
      country: 'f-country'
    };

    function typeIcon(type) {
      return type === 'Home' ? '&#127968;' : type === 'Work' ? '&#127970;' : '&#128205;';
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function getAddressDataFromForm() {
      return {
        name: document.getElementById('f-name').value.trim(),
        phone: document.getElementById('f-phone').value.trim(),
        addr1: document.getElementById('f-addr1').value.trim(),
        addr2: document.getElementById('f-addr2').value.trim(),
        city: document.getElementById('f-city').value.trim(),
        state: document.getElementById('f-state').value.trim(),
        zip: document.getElementById('f-zip').value.trim(),
        country:"India",
        type: document.getElementById('f-type').value,
        default: document.getElementById('f-default').checked
      };
    }

    function setFieldError(fieldId, message) {
      const input = document.getElementById(fieldId);
      if (!input) return;

      let errorNode = input.parentElement.querySelector('.field-error');
      if (!errorNode) {
        errorNode = document.createElement('div');
        errorNode.className = 'field-error';
        input.parentElement.appendChild(errorNode);
      }

      errorNode.textContent = message || '';
      input.classList.toggle('input-error', Boolean(message));
    }

    function clearValidationErrors() {
      Object.values(fieldMap).forEach((fieldId) => setFieldError(fieldId, ''));
    }

    function applyValidationErrors(errors = {}) {
      Object.entries(errors).forEach(([field, messages]) => {
        const fieldId = fieldMap[field];
        if (fieldId && messages && messages.length > 0) {
          setFieldError(fieldId, messages[0]);
        }
      });
    }

    function setSaveButtonState(isLoading, loadingText = 'Saving...') {
      const button = document.getElementById('saveAddressBtn');
      if (!button) return;
      button.disabled = isLoading;
      button.textContent = isLoading ? loadingText : (editId ? 'Update Address' : 'Save Address');
    }

    function parseId(value) {
      if (typeof value === 'string') return value;
      if (value && typeof value === 'object' && value.$oid) return value.$oid;
      return String(value || '');
    }

    function render() {
      const list = document.getElementById('addressList');

      if (addresses.length === 0) {
        list.innerHTML = `
        <div class="empty-state">
          <div class="empty-icon">&#128205;</div>
          <h3>No addresses saved</h3>
          <p>Add a delivery address to make checkout faster and easier.</p>
          <button class="btn btn-primary" onclick="openModal()" style="margin-top:8px;">Add Your First Address</button>
        </div>`;
        return;
      }

      list.innerHTML = addresses.map((address) => {
        const id = parseId(address._id);
        const isDefault = Boolean(address.default);

        return `
      <div class="address-card ${isDefault ? 'default' : ''}" id="card-${id}">
        <div class="card-top">
          <div class="card-label">
            <span class="card-type">${typeIcon(address.type)} ${escapeHtml(address.type)}</span>
            ${isDefault ? '<span class="badge-default">Default</span>' : ''}
          </div>
          <div class="card-actions">
            <button class="action-btn action-edit" onclick="openEdit('${id}')">Edit</button>
            <button class="action-btn action-delete" onclick="openDelete('${id}')">Delete</button>
          </div>
        </div>
        <div class="address-name">${escapeHtml(address.name)}</div>
        <div class="address-line">
          ${escapeHtml(address.addr1)}${address.addr2 ? ', ' + escapeHtml(address.addr2) : ''}<br/>
          ${escapeHtml(address.city)}, ${escapeHtml(address.state)} ${escapeHtml(address.zip)}<br/>
          ${escapeHtml(address.country)}
        </div>
        <div class="address-phone">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          ${escapeHtml(address.phone)}
        </div>
        <div class="card-footer">
          <button class="set-default-btn" onclick="setDefault('${id}')" ${isDefault ? 'disabled' : ''}>
            <span class="radio-dot"></span>
            ${isDefault ? 'Default address' : 'Set as default'}
          </button>
        </div>
      </div>`;
      }).join('');
    }

    function clearForm() {
      ['f-name', 'f-phone', 'f-addr1', 'f-addr2', 'f-city', 'f-state', 'f-zip'].forEach((id) => {
        document.getElementById(id).value = '';
      });
      document.getElementById('f-country').value = 'United States';
      document.getElementById('f-type').value = 'Home';
      document.getElementById('f-default').checked = false;
      clearValidationErrors();
      setSaveButtonState(false);
    }

    function openModal() {
      editId = null;
      document.getElementById('modalTitle').textContent = 'Add New Address';
      clearForm();
      document.getElementById('formModal').classList.add('open');
    }

    function openEdit(id) {
      const address = addresses.find((entry) => parseId(entry._id) === id);
      if (!address) return;

      editId = id;
      document.getElementById('modalTitle').textContent = 'Edit Address';
      document.getElementById('f-name').value = address.name || '';
      document.getElementById('f-phone').value = address.phone || '';
      document.getElementById('f-addr1').value = address.addr1 || '';
      document.getElementById('f-addr2').value = address.addr2 || '';
      document.getElementById('f-city').value = address.city || '';
      document.getElementById('f-state').value = address.state || '';
      document.getElementById('f-zip').value = address.zip || '';
      document.getElementById('f-country').value = address.country || 'United States';
      document.getElementById('f-type').value = address.type || 'Home';
      document.getElementById('f-default').checked = Boolean(address.default);
      clearValidationErrors();
      setSaveButtonState(false);
      document.getElementById('formModal').classList.add('open');
    }

    function closeModal() {
      document.getElementById('formModal').classList.remove('open');
    }

    async function parseResponseJson(response) {
      try {
        return await response.json();
      } catch (_) {
        return { success: false, message: 'Unexpected server response.' };
      }
    }
    
    async function saveAddress() {
      console.log("phone")
      const data = getAddressDataFromForm();
      clearValidationErrors();

      let valid =true;

      const phoneRegex = /^[6-9]¥d{9}$/;
      const pinRegex = /^[1-9][0-9]{5}$/;
      
      if (!phoneRegex.test(data.phone)) {
        setFieldError("f-phone", "Enter a valid 10-digit Indian phone number");
        valid = false;
      }
      
      if (!pinRegex.test(data.zip)) {
        setFieldError("f-zip", "Enter a valid 6-digit PIN code");
        valid = false;
      }
      
      if (!data.name) {
        setFieldError("f-name", "Full name is required");
        valid = false;
      }
      
      if (!data.addr1) {
        setFieldError("f-addr1", "Address is required");
        valid = false;
      }
      
      if (!valid) return;

      setSaveButtonState(true, editId ? 'Updating...' : 'Saving...');

      try {
        const endpoint = editId ? `/address/${editId}` : '/address';
        const method = editId ? 'PUT' : 'POST';

        const response = await fetch(endpoint, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await parseResponseJson(response);
        console.log("Server result:", result);

        if (!response.ok || !result.success) {
          applyValidationErrors(result.errors || {});
          showToast(result.message || (editId ? 'Unable to update address.' : 'Unable to add address.'), false);
          return;
        }

        if (result.address &&   result.address.default) {
          addresses.forEach((entry) => {
            entry.default = parseId(entry._id) === parseId(result.address._id);
          });
        }

        if (editId) {
          const index = addresses.findIndex((entry) => parseId(entry._id) === editId);
          if (index !== -1) addresses[index] = result.address;
          showToast('Address updated successfully!');
        } else {
          addresses.push(result.address);
          showToast('Address added successfully!');
        }


        closeModal();
        render();

      } catch (error) {
        console.error('Save address failed:', error);
       console.error(error.stack)
        showToast('Unable to validate address right now. Please try again.', false);
      } finally {
        setSaveButtonState(false);
      }
    }

    function openDelete(id) {
      deleteId = id;
      document.getElementById('deleteModal').classList.add('open');
    }

    function closeDelete() {
      document.getElementById('deleteModal').classList.remove('open');
      deleteId = null;
    }

    async function confirmDelete() {
      try {
        const response = await fetch(`/address/${deleteId}`, { method: 'DELETE' });
        const result = await parseResponseJson(response);

        if (!response.ok || !result.success) {
          showToast(result.message || 'Delete failed.', false);
          return;
        }

        addresses = addresses.filter((entry) => parseId(entry._id) !== deleteId);
        showToast('Address deleted.');
        closeDelete();
        render();
      } catch (error) {
        console.error('Delete address failed:', error);
        showToast('Unable to delete address right now.', false);
      }
    }

    async function setDefault(id) {
      try {
        const response = await fetch(`/address/default/${id}`, { method: 'PATCH' });
        const result = await parseResponseJson(response);

        if (!response.ok || !result.success) {
          showToast(result.message || 'Could not set default address.', false);
          return;
        }

        addresses.forEach((entry) => {
          entry.default = parseId(entry._id) === id;
        });
        render();
        showToast('Default address updated!');
      } catch (error) {
        console.error('Set default failed:', error);
        showToast('Could not set default address right now.', false);
      }
    }

    function showToast(msg, success = true) {
      const toast = document.getElementById('toast');
      toast.textContent = msg;
      toast.className = 'toast' + (success ? ' success' : '');
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }

    Object.values(fieldMap).forEach((fieldId) => {
      const field = document.getElementById(fieldId);
      if (!field) return;
      field.addEventListener('input', () => setFieldError(fieldId, ''));
      field.addEventListener('change', () => setFieldError(fieldId, ''));
    });

    document.getElementById('formModal').addEventListener('click', (event) => {
      if (event.target === event.currentTarget) closeModal();
    });

    document.getElementById('deleteModal').addEventListener('click', (event) => {
      if (event.target === event.currentTarget) closeDelete();
    });

    render();
  </script>
</body>

</html>