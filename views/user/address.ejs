鬠ｿ<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Starzo - Address</title>
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap"
    rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --blue: #2563EB;
      --blue-light: #EFF6FF;
      --blue-mid: #DBEAFE;
      --text: #111827;
      --muted: #6B7280;
      --border: #E5E7EB;
      --bg: #F3F4F6;
      --white: #FFFFFF;
      --danger: #EF4444;
      --success: #10B981;
      --sidebar-active: #EFF6FF;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ NAV ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ */
    nav {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 32px;
      height: 56px;
      gap: 32px;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .nav-brand {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 700;
      font-size: 18px;
      color: var(--blue);
      text-decoration: none;
    }

    .nav-brand-icon {
      width: 28px;
      height: 28px;
      background: var(--blue);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 14px;
      font-weight: 800;
    }

    .nav-links {
      display: flex;
      gap: 24px;
      list-style: none;
      flex: 1;
    }

    .nav-links a {
      text-decoration: none;
      color: var(--muted);
      font-size: 14px;
      font-weight: 500;
      transition: color .15s;
    }

    .nav-links a:hover {
      color: var(--text);
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-left: auto;
    }

    .nav-icon-btn {
      width: 34px;
      height: 34px;
      border: none;
      background: none;
      cursor: pointer;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      transition: background .15s, color .15s;
    }

    .nav-icon-btn:hover {
      background: var(--bg);
      color: var(--text);
    }

    .nav-avatar {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      background: #CBD5E1;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 13px;
      color: #475569;
    }

    /* ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ LAYOUT ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ */
    .layout {
      max-width: 1100px;
      margin: 32px auto;
      padding: 0 24px;
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 24px;
      align-items: start;
    }

    /* ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ SIDEBAR ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ */
    .sidebar {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 1px 4px rgba(0, 0, 0, .05);
    }

    .sidebar-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 11px 18px;
      font-size: 14px;
      font-weight: 500;
      color: var(--muted);
      cursor: pointer;
      text-decoration: none;
      transition: background .12s, color .12s;
      border-left: 3px solid transparent;
    }

    .sidebar-item:hover {
      background: var(--bg);
      color: var(--text);
    }

    .sidebar-item.active {
      background: var(--sidebar-active);
      color: var(--blue);
      border-left-color: var(--blue);
      font-weight: 600;
    }

    .sidebar-divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 4px 0;
    }

    .sidebar-item .si-icon {
      width: 16px;
      height: 16px;
      opacity: .7;
      flex-shrink: 0;
    }

    .sidebar-item.active .si-icon {
      opacity: 1;
    }

    .sidebar-signout {
      color: #EF4444 !important;
    }

    .sidebar-signout .si-icon {
      color: #EF4444;
      opacity: 1;
    }

    /* ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ MAIN CONTENT ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ */
    .content {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 14px;
      box-shadow: 0 1px 4px rgba(0, 0, 0, .05);
      overflow: hidden;
    }

    .content-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 28px;
      border-bottom: 1px solid var(--border);
    }

    .content-title {
      font-size: 17px;
      font-weight: 700;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      font-family: inherit;
      transition: opacity .15s, box-shadow .15s, background .15s;
    }

    .btn:hover {
      opacity: .9;
    }

    .btn-primary {
      background: var(--blue);
      color: white;
    }

    .btn-primary:hover {
      box-shadow: 0 4px 12px rgba(37, 99, 235, .3);
    }

    .btn-outline {
      background: none;
      color: var(--text);
      border: 1px solid var(--border);
    }

    .btn-outline:hover {
      background: var(--bg);
    }

    .btn-danger-outline {
      background: none;
      color: var(--danger);
      border: 1px solid #FECACA;
    }

    .btn-danger-outline:hover {
      background: #FFF5F5;
    }

    /* ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ ADDRESS LIST ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ */
    .address-list {
      padding: 24px 28px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .address-card {
      border: 1.5px solid var(--border);
      border-radius: 12px;
      padding: 20px;
      position: relative;
      transition: border-color .15s, box-shadow .15s;
    }

    .address-card:hover {
      border-color: #93C5FD;
      box-shadow: 0 0 0 3px rgba(37, 99, 235, .07);
    }

    .address-card.default {
      border-color: var(--blue);
      background: var(--blue-light);
    }

    .card-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 12px;
    }

    .card-label {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .card-type {
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
    }

    .badge-default {
      background: var(--blue);
      color: white;
      font-size: 10px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 20px;
      letter-spacing: .4px;
      text-transform: uppercase;
    }

    .card-actions {
      display: flex;
      gap: 8px;
    }

    .action-btn {
      border: none;
      background: none;
      cursor: pointer;
      font-size: 13px;
      font-weight: 600;
      padding: 4px 10px;
      border-radius: 6px;
      font-family: inherit;
      transition: background .12s, color .12s;
    }

    .action-edit {
      color: var(--blue);
    }

    .action-edit:hover {
      background: var(--blue-mid);
    }

    .action-delete {
      color: var(--danger);
    }

    .action-delete:hover {
      background: #FEE2E2;
    }

    .address-name {
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 4px;
    }

    .address-line {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
    }

    .address-phone {
      font-size: 13px;
      color: var(--muted);
      margin-top: 6px;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .card-footer {
      margin-top: 14px;
      padding-top: 14px;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .address-card.default .card-footer {
      border-top-color: #BFDBFE;
    }

    .set-default-btn {
      border: none;
      background: none;
      cursor: pointer;
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      font-family: inherit;
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 0;
      transition: color .12s;
    }

    .set-default-btn:hover {
      color: var(--blue);
    }

    .radio-dot {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      border: 2px solid currentColor;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .radio-dot::after {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: transparent;
    }

    .address-card.default .set-default-btn {
      color: var(--blue);
    }

    .address-card.default .radio-dot::after {
      background: var(--blue);
    }

    /* ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ MODAL OVERLAY ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .45);
      backdrop-filter: blur(2px);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 999;
      opacity: 0;
      pointer-events: none;
      transition: opacity .2s;
    }

    .modal-overlay.open {
      opacity: 1;
      pointer-events: all;
    }

    .modal {
      background: var(--white);
      border-radius: 16px;
      padding: 28px;
      width: 520px;
      max-width: 95vw;
      box-shadow: 0 20px 60px rgba(0, 0, 0, .18);
      transform: translateY(12px) scale(.97);
      transition: transform .2s, opacity .2s;
      opacity: 0;
    }

    .modal-overlay.open .modal {
      transform: translateY(0) scale(1);
      opacity: 1;
    }

    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 22px;
    }

    .modal-title {
      font-size: 16px;
      font-weight: 700;
    }

    .modal-close {
      width: 32px;
      height: 32px;
      border: none;
      background: var(--bg);
      border-radius: 8px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      color: var(--muted);
      transition: background .12s, color .12s;
    }

    .modal-close:hover {
      background: var(--border);
      color: var(--text);
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .form-group.full {
      grid-column: 1 / -1;
    }

    label {
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: .3px;
      text-transform: uppercase;
    }

    input,
    select {
      border: 1.5px solid var(--border);
      border-radius: 8px;
      padding: 9px 12px;
      font-size: 14px;
      font-family: 'DM Sans', sans-serif;
      color: var(--text);
      background: var(--white);
      outline: none;
      transition: border-color .15s, box-shadow .15s;
    }

    input:focus,
    select:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, .1);
    }

    input.input-error,
    select.input-error {
      border-color: var(--danger);
      box-shadow: 0 0 0 3px rgba(239, 68, 68, .14);
    }

    .field-error {
      min-height: 16px;
      color: var(--danger);
      font-size: 11px;
      font-weight: 500;
      line-height: 1.3;
    }

    input::placeholder {
      color: #9CA3AF;
    }

    .form-check {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 8px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      color: var(--text);
      user-select: none;
    }

    .form-check input[type="checkbox"] {
      width: 16px;
      height: 16px;
      accent-color: var(--blue);
      cursor: pointer;
      padding: 0;
      box-shadow: none;
    }

    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-top: 24px;
      padding-top: 20px;
      border-top: 1px solid var(--border);
    }

    .btn[disabled] {
      cursor: not-allowed;
      opacity: .72;
      box-shadow: none !important;
    }

    /* ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ EMPTY STATE ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ */
    .empty-state {
      padding: 60px 28px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      color: var(--muted);
      text-align: center;
    }

    .empty-icon {
      width: 56px;
      height: 56px;
      background: var(--bg);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 26px;
      margin-bottom: 4px;
    }

    .empty-state h3 {
      font-size: 15px;
      font-weight: 700;
      color: var(--text);
    }

    .empty-state p {
      font-size: 13px;
      max-width: 260px;
    }

    /* ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ DELETE CONFIRM ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ */
    .confirm-modal {
      max-width: 380px;
      text-align: center;
    }

    .confirm-icon {
      width: 52px;
      height: 52px;
      background: #FEE2E2;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      margin: 0 auto 16px;
    }

    .confirm-modal h3 {
