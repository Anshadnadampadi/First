      font-weight: 700;
      margin-bottom: 8px;
    }

    .confirm-modal p {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
    }

    .confirm-modal .modal-footer {
      justify-content: center;
    }

    /* ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ TOAST ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ */
    .toast {
      position: fixed;
      bottom: 24px;
      right: 24px;
      background: var(--text);
      color: white;
      padding: 12px 18px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 500;
      box-shadow: 0 8px 24px rgba(0, 0, 0, .2);
      z-index: 9999;
      transform: translateY(80px);
      opacity: 0;
      transition: transform .25s, opacity .25s;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .toast.show {
      transform: translateY(0);
      opacity: 1;
    }

    .toast.success::before {
      content: '¥2713';
      color: var(--success);
      font-weight: 700;
    }

    /* ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ RESPONSIVE ﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎﾃ｢窶昶ぎ */
    @media (max-width: 900px) {
      nav {
        padding: 10px 14px;
        height: auto;
        gap: 14px;
        flex-wrap: wrap;
      }

      .nav-links {
        order: 3;
        width: 100%;
        gap: 14px;
        overflow-x: auto;
        white-space: nowrap;
      }

      .layout {
        margin: 20px auto;
        padding: 0 14px;
      }

      .content-header {
        flex-wrap: wrap;
        gap: 10px;
        padding: 16px 18px;
      }

      .address-list {
        padding: 18px;
      }
    }

    @media(max-width: 740px) {
      .layout {
        grid-template-columns: 1fr;
      }

      .sidebar {
        display: flex;
        overflow-x: auto;
        border-radius: 10px;
      }

      .sidebar-item {
        white-space: nowrap;
        border-left: none;
