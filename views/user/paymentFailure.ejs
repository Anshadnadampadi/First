<!-- views/user/paymentFailure.ejs -->
<%- contentFor('body') %>

<div class="min-h-[80vh] bg-[#050505] flex items-center justify-center py-20 px-6 relative overflow-hidden">
    <!-- Background Accents -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-status-danger/5 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute top-0 left-0 w-full h-[300px] bg-gradient-to-b from-status-danger/[0.03] to-transparent pointer-events-none"></div>

    <div class="max-w-xl w-full text-center relative z-10">
        <!-- Error Hologram Icon -->
        <div class="mb-10 relative inline-block group">
            <div class="absolute inset-0 bg-status-danger/20 rounded-full blur-2xl group-hover:bg-status-danger/30 transition-all duration-700 animate-pulse"></div>
            <div class="relative w-24 h-24 bg-black border-2 border-status-danger flex items-center justify-center rounded-full shadow-[0_0_50px_rgba(255,59,48,0.2)]">
                <svg class="w-12 h-12 text-status-danger" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </div>
            
            <!-- Scanning lines decoration -->
            <div class="absolute -left-4 -right-4 top-1/2 h-[1px] bg-status-danger/30 blur-[1px] animate-pulse"></div>
        </div>

        <h1 class="text-white text-4xl font-black tracking-tighter uppercase mb-4">
            Payment <span class="text-status-danger">Failed</span>
        </h1>
        
        <p class="text-white/40 font-mono text-[11px] uppercase tracking-[0.3em] mb-12 max-w-sm mx-auto leading-relaxed">
            Transaction aborted by the gateway. <br>
            Your security protocols remained intact.
        </p>

        <div class="bg-white/[0.02] border border-white/5 backdrop-blur-md p-8 mb-10 text-left relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-1 h-full bg-status-danger transform origin-bottom scale-y-0 group-hover:scale-y-100 transition-transform duration-500"></div>
            
            <h3 class="text-white/60 text-[10px] font-black uppercase tracking-widest mb-6 border-b border-white/5 pb-4 flex items-center gap-2">
                <span class="w-1.5 h-1.5 bg-status-danger rounded-full"></span>
                Incident Report
            </h3>

            <div class="space-y-4">
                <div class="flex justify-between items-center border-b border-white/[0.03] pb-3">
                    <span class="text-white/30 text-[9px] font-bold uppercase tracking-widest">Order Reference</span>
                    <span class="text-white font-mono text-[10px]"><%= orderId %></span>
                </div>
                <div class="flex justify-between items-center border-b border-white/[0.03] pb-3">
                    <span class="text-white/30 text-[9px] font-bold uppercase tracking-widest">Gateway Status</span>
                    <span class="text-status-danger font-black text-[9px] uppercase tracking-widest">Payment Refused</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-white/30 text-[9px] font-bold uppercase tracking-widest">Timestamp</span>
                    <span class="text-white/60 font-mono text-[10px]"><%= new Date().toLocaleString() %></span>
                </div>
            </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/checkout" class="bg-white text-black font-black px-10 py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-status-danger hover:text-white transition-all shadow-[0_0_30px_rgba(255,255,255,0.1)]">
                Try Again
            </a>
            <a href="/account/orders" class="border border-white/10 text-white font-bold px-10 py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-white/5 transition-all">
                Order History
            </a>
        </div>
        
        <p class="mt-12 text-white/20 text-[8px] font-black uppercase tracking-[0.4em]">
            Need help? Contact support via encrypted channel.
        </p>
    </div>
</div>
