<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OTP Verification</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<style>
body {
    background: #f4f6f9;
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
    padding: 20px 12px;
}

.otp-card {
    max-width: 420px;
    margin: 60px auto;
    padding: 40px;
    border-radius: 18px;
    background: #fff;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
    text-align: center;
}

.icon-circle {
    width: 60px;
    height: 60px;
    background: #e7f0ff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    font-size: 26px;
    color: #2563eb;
}

.otp-inputs {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin: 25px 0;
}

.otp-inputs input {
    width: 45px;
    height: 50px;
    font-size: 18px;
    text-align: center;
    border-radius: 8px;
    border: 1px solid #ddd;
    outline: none;
}

.otp-inputs input:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.15);
}

.timer {
    font-size: 14px;
    color: #2563eb;
    margin-bottom: 20px;
}

.btn-primary {
    height: 48px;
    border-radius: 10px;
    font-weight: 600;
}

.resend-link {
    font-size: 14px;
}

.secure-text {
    font-size: 12px;
    color: #888;
    margin-top: 20px;
}

@media (max-width: 576px) {
    .otp-card {
        margin: 24px auto;
        padding: 26px 18px;
        border-radius: 14px;
    }

    .otp-inputs {
        gap: 6px;
        margin: 20px 0;
    }

    .otp-inputs input {
        width: 40px;
        height: 46px;
        font-size: 17px;
    }
}
</style>
</head>

<body>
<div class="otp-card">
    <div class="icon-circle">&#128241;</div>

    <h5 class="fw-bold">OTP Verification</h5>
    <p class="text-muted small">
        We've sent a 6-digit verification code to your device.
        Please enter the code below to recover your account.
    </p>

    <form id="otpForm" action="/verify-otp" method="post">
        <div class="otp-inputs">
            <input type="text" maxlength="1" class="otp-box" required inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code">
            <input type="text" maxlength="1" class="otp-box" required inputmode="numeric" pattern="[0-9]*">
            <input type="text" maxlength="1" class="otp-box" required inputmode="numeric" pattern="[0-9]*">
            <input type="text" maxlength="1" class="otp-box" required inputmode="numeric" pattern="[0-9]*">
            <input type="text" maxlength="1" class="otp-box" required inputmode="numeric" pattern="[0-9]*">
            <input type="text" maxlength="1" class="otp-box" required inputmode="numeric" pattern="[0-9]*">
        </div>

        <input type="hidden" name="email" value="<%= email || '' %>">
        <input type="hidden" name="context" value="<%= context || 'signup' %>">
        <input type="hidden" name="otp" id="fullOtp">

        <div class="timer">
            &#9203; Code expires in <span id="countdown">01:00</span>
        </div>

        <button type="submit" class="btn btn-primary w-100">
            Verify & Proceed
        </button>

        <div class="mt-3 resend-link">
            Didn't receive the code?
            <a href="/resend-otp?email=<%= encodeURIComponent(email || '') %>&context=<%= context || 'signup' %>">Resend Code</a>
        </div>
    </form>

    <div class="secure-text mt-4">
        &#128274; Secure End-to-End Encryption
    </div>
</div>

<script>
const inputs = document.querySelectorAll(".otp-box");

inputs.forEach((input, index) => {
    input.addEventListener("input", () => {
        input.value = input.value.replace(/\D/g, "");
        if (input.value.length === 1 && index < inputs.length - 1) {
            inputs[index + 1].focus();
        }
    });

    input.addEventListener("keydown", (e) => {
        if (e.key === "Backspace" && !input.value && index > 0) {
            inputs[index - 1].focus();
        }
    });
});

document.getElementById("otpForm").addEventListener("submit", function (e) {
    let otp = "";
    inputs.forEach(input => {
        otp += input.value;
    });

    if (otp.length !== 6) {
        e.preventDefault();
        alert("Please enter complete 6-digit OTP");
        return;
    }

    document.getElementById("fullOtp").value = otp;
});

let time = 60;
const countdownElement = document.getElementById("countdown");

const timer = setInterval(() => {
    const minutes = Math.floor(time / 60);
    const seconds = time % 60;

    countdownElement.textContent =
        `${minutes.toString().padStart(2, "0")}:${seconds.toString().padStart(2, "0")}`;

    if (time <= 0) {
        clearInterval(timer);
        countdownElement.textContent = "Expired";
    }

    time--;
}, 1000);


<% if (error) { %>

Toastify({
    text: "<%= error %>",
    duration: 3000,
    gravity: "top",
    position: "right",
    backgroundColor: "#ef4444",
    stopOnFocus: true
}).showToast();

<% } %>
</script>
</body>
</html>
