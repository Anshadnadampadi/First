<!-- views/user/account/index.ejs -->
<%- contentFor('body') %>

<div class="min-h-screen bg-black py-12 md:py-24">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 md:mb-16 gap-6 md:gap-8">
            <div class="fade-up" x-data="{}">
                <span class="text-accent text-label font-bold uppercase mb-4 block">Welcome Back</span>
                <h1 class="text-white text-display font-bold tracking-tight uppercase font-display"><%= (user.firstName || user.name || user.email.split('@')[0]) %>'s Account.</h1>
                <a href="/auth/logout" 
                   @click.prevent="if(await window.confirmAction({ title: 'Logout?', message: 'Are you sure you want to end your session?', confirmText: 'Logout', cancelText: 'Cancel', type: 'danger' })) window.location.href='/auth/logout'"
                   class="text-text-muted hover:text-white text-label font-bold uppercase border-b border-black-border pb-1 transition-all mt-4 inline-block">Sign Out</a>
            </div>

        </div>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
            <!-- Sidebar Nav -->
            <%- include('../../partials/account-sidebar', { activeTab: 'dashboard' }) %>

            <!-- Main Panel -->
            <div class="lg:col-span-3 space-y-8 md:space-y-12">
                <!-- Stats / Quick Look -->
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
                    <div class="bg-[#0a0a0a] border border-white/[0.03] shadow-lg p-5 md:p-8">
                        <h4 class="text-text-muted text-[9px] font-bold tracking-widest uppercase mb-4">Total Orders</h4>
                        <p class="text-white text-4xl font-mono font-bold"><%= typeof orderCount !== 'undefined' ? orderCount : 0 %></p>
                    </div>
                    <div class="bg-black-card border border-black-border p-8">
                        <h4 class="text-text-muted text-[9px] font-bold tracking-widest uppercase mb-4">In Wishlist</h4>
                        <p class="text-white text-3xl md:text-4xl font-mono font-bold"><%= typeof wishlistCount !== 'undefined' ? wishlistCount : 0 %></p>
                    </div>
                    <div class="bg-[#0a0a0a] border border-white/[0.03] shadow-lg p-5 md:p-8 col-span-2 md:col-span-1">
                        <h4 class="text-white/40 text-[8px] md:text-[9px] font-bold tracking-widest uppercase mb-4">Member Since</h4>
                        <p class="text-white text-sm font-bold uppercase tracking-widest mt-2"><%= new Date(user.createdAt).toLocaleDateString('en-IN', { month: 'short', year: 'numeric' }) %></p>
                    </div>
                </div>

                <!-- Recent Order -->
                <div class="bg-[#0a0a0a] border border-white/[0.03] shadow-lg overflow-hidden relative group">
                    <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-white/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="px-5 md:px-8 py-5 md:py-6 border-b border-white/[0.03] flex justify-between items-center bg-white/[0.01]">
                        <h3 class="text-white text-[10px] md:text-[11px] font-black tracking-[0.2em] uppercase">Latest Order</h3>
                        <a href="/account/orders" class="text-accent text-[9px] font-bold uppercase tracking-widest hover:text-white transition-colors">View All</a>
                    </div>
                    <div class="p-5 md:p-8">
                        <% if (typeof latestOrder !== 'undefined' && latestOrder) { %>
                            <a href="/account/orders/<%= latestOrder._id %>" class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 md:gap-12 hover:opacity-80 transition-opacity">
                                <div class="flex gap-4 md:gap-6 items-center">
                                    <div class="w-16 h-16 flex-shrink-0 bg-black p-2 border border-white/5 flex items-center justify-center">
                                        <img src="<%= latestOrder.items[0].product.images[0] || '/images/placeholder.png' %>" class="max-w-full max-h-full object-contain">
                                    </div>
                                    <div>
                                        <p class="text-white text-xs font-bold uppercase"><%= latestOrder.items[0].product.name %></p>
                                        <p class="text-white/30 text-[9px] mt-1.5 tracking-widest uppercase font-mono">#<%= latestOrder.orderId %> · <%= new Date(latestOrder.createdAt).toLocaleDateString() %></p>
                                    </div>
                                </div>
                                <div class="w-full md:w-auto text-left md:text-right border-t md:border-t-0 border-white/[0.03] pt-4 md:pt-0 mt-2 md:mt-0">
                                    <%- include('../../partials/status-badge', { status: latestOrder.status }) %>
                                    <p class="text-white font-mono font-bold text-lg mt-3">₹<%= latestOrder.totalAmount.toLocaleString() %></p>
                                </div>
                            </a>
                        <% } else { %>
                            <p class="text-white/20 text-xs italic py-4">No recent orders found.</p>
                        <% } %>
                    </div>
                </div>

                <!-- Profile Info -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-12">
                    <div class="bg-[#0a0a0a] border border-white/[0.03] p-6 md:p-8 shadow-lg flex flex-col justify-between">
                        <div class="space-y-6">
                            <h3 class="text-white text-[10px] tracking-[0.2em] font-black uppercase border-b border-white/[0.03] pb-4">Personal Details</h3>
                            <div class="space-y-5">
                                <div>
                                    <p class="text-white/40 text-[9px] font-bold uppercase tracking-widest mb-1">Name</p>
                                    <p class="text-white text-[13px] font-bold"><%= (user.firstName || user.name || user.email.split('@')[0]) %> <%= (user.lastName || '') %></p>
                                </div>
                                <div>
                                    <p class="text-white/40 text-[9px] font-bold uppercase tracking-widest mb-1">Email</p>
                                    <p class="text-white text-[13px] font-mono"><%= user.email %></p>
                                </div>
                            </div>
                        </div>
                        <a href="/profile" class="mt-8 text-center block w-full bg-white text-black text-[10px] font-black uppercase tracking-[0.2em] px-4 py-3 hover:bg-accent transition-all">Edit Profile</a>
                    </div>

                    <div class="bg-[#0a0a0a] border border-white/[0.03] p-6 md:p-8 shadow-lg flex flex-col justify-between">
                        <div class="space-y-6">
                            <h3 class="text-white text-[10px] tracking-[0.2em] font-black uppercase border-b border-white/[0.03] pb-4">Default Address</h3>
                            <% if (typeof defaultAddress !== 'undefined' && defaultAddress) { %>
                                <div class="text-white/60 text-[13px] leading-relaxed">
                                    <p class="font-bold text-white mb-2 uppercase tracking-wide"><%= defaultAddress.name %></p>
                                    <p><%= defaultAddress.street %></p>
                                    <p><%= defaultAddress.city %>, <%= defaultAddress.state %> - <%= defaultAddress.pincode %></p>
                                    <p class="mt-3 text-accent text-[9px] uppercase tracking-widest font-bold">Default Shipping</p>
                                </div>
                            <% } else { %>
                                <div class="py-6 text-center">
                                    <p class="text-white/30 text-[10px] uppercase tracking-widest font-bold mb-2">No address saved yet</p>
                                    <p class="text-white/20 text-xs">Add an address to checkout faster.</p>
                                </div>
                            <% } %>
                        </div>
                        <a href="/account/address" class="mt-8 text-center block w-full border border-white/10 text-white text-[10px] font-black uppercase tracking-[0.2em] px-4 py-3 hover:bg-white hover:text-black transition-all">Manage Addresses</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
