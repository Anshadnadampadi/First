<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile - MobileStore</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">

    <style>
        body { font-family: 'DM Sans', sans-serif; }
        .input-focus {
            transition: all 0.2s ease;
        }
        .input-focus:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }
    </style>
</head>

<body class="bg-[#f8fafc] min-h-screen py-8 px-4 sm:px-6 lg:px-8">

    <div class="max-w-3xl mx-auto">
        
        <a href="/profile" class="inline-flex items-center gap-2 text-slate-500 hover:text-indigo-600 transition-colors mb-6 group">
            <span class="material-icons-round text-lg group-hover:-translate-x-1 transition-transform">arrow_back</span>
            <span class="font-medium text-sm">Back to Profile</span>
        </a>

        <form class="bg-white rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 overflow-hidden" 
              id="editProfileForm" method="POST" action="/editProfile" enctype="multipart/form-data">

            <div class="px-8 py-6 border-b border-slate-50">
                <h2 class="text-xl font-bold text-slate-800">Edit Profile</h2>
                <p class="text-slate-500 text-sm mt-1">Manage your public information and account settings.</p>
            </div>

            <div class="p-8 space-y-8">

                <div class="flex flex-col sm:flex-row items-center gap-6 pb-6 border-b border-slate-50">
                    <div class="relative group">
                        <img id="avatarImg" class="w-24 h-24 rounded-full object-cover ring-4 ring-slate-50 shadow-sm"
                            src="<%= user && user.profileImage ? user.profileImage : '/images/default-avatar.png' %>">
                    </div>
                    
                    <div class="flex flex-wrap gap-3">
                        <button type="button" 
                                class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-all shadow-md shadow-indigo-100"
                                onclick="document.getElementById('profileImage').click()">
                            Change Photo
                        </button>
                        <button type="button" 
                                class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 text-sm font-semibold rounded-lg transition-all"
                                onclick="removePhoto()">
                            Remove
                        </button>
                    </div>
                    <input type="file" id="profileImage" name="profileImage"
                        accept="image/jpeg,image/png,image/webp,image/gif" class="hidden"
                        onchange="previewPhoto(event)">
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-5">
                    
                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Full Name</label>
                        <input id="fullName" name="fullName" value="<%= user ? user.name : '' %>"
                               class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50/50 input-focus outline-none text-slate-700">
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Display Name</label>
                        <input id="displayName" name="displayName" value="<%= user && user.displayName ? user.displayName : '' %>"
                               class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50/50 input-focus outline-none text-slate-700">
                    </div>

                    <div class="space-y-1.5 md:col-span-1">
                        <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Email</label>
                        <div class="flex gap-2">
                            <input id="email" value="<%= user ? user.email : '' %>" readonly
                                   class="flex-grow px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-100 text-slate-500 cursor-not-allowed outline-none">
                            <button type="button" 
                                    class="px-4 py-2.5 bg-white border border-slate-200 hover:border-indigo-600 hover:text-indigo-600 text-slate-600 font-semibold rounded-xl transition-all text-sm"
                                    onclick="openEmailModal()">
                                Edit
                            </button>
                        </div>
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Phone</label>
                        <input id="phone" name="phone" value="<%= user && user.phone ? user.phone : '' %>"
                               class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50/50 input-focus outline-none text-slate-700">
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Date of Birth</label>
                        <input type="date" id="dob" name="dob" value="<%= user && user.dob ? user.dob.toISOString().split('T')[0] : '' %>"
                               class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50/50 input-focus outline-none text-slate-700">
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Location</label>
                        <input name="location" value="<%= user && user.location ? user.location : '' %>"
                               class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50/50 input-focus outline-none text-slate-700">
                    </div>

                </div>

                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Bio</label>
                    <textarea name="bio" rows="4"
                              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50/50 input-focus outline-none text-slate-700 resize-none"><%= user && user.bio ? user.bio : '' %></textarea>
                </div>

            </div>

            <div class="px-8 py-6 bg-slate-50/50 border-t border-slate-100 flex flex-col-reverse sm:flex-row justify-end gap-3">
                <button type="button" class="px-6 py-2.5 text-slate-600 font-bold hover:text-slate-800 transition-colors" 
                        onclick="cancelEdit()">Cancel</button>
                <button type="submit" 
                        class="px-8 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-all shadow-lg shadow-indigo-200 active:scale-95">
                    Save Changes
                </button>
            </div>

        </form>
    </div>

    <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 hidden items-center justify-center p-4" id="emailModal">
        <div class="bg-white rounded-2xl p-8 w-full max-w-md shadow-2xl scale-100 transition-transform">
            <h3 class="text-lg font-bold text-slate-800 mb-2">Change Email</h3>
            <p class="text-slate-500 text-sm mb-6">Enter your new email address to receive a verification code.</p>

            <div class="space-y-4">
                <input id="newEmail" type="email" placeholder="name@example.com"
                       class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 input-focus outline-none">
                
                <input id="emailOtp" type="text" maxlength="6" placeholder="Enter 6-digit OTP" 
                       class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 input-focus outline-none text-center tracking-[1em] font-bold hidden">

                <div id="otpHint" class="hidden flex items-center gap-2 p-3 bg-blue-50 text-blue-700 rounded-lg text-xs leading-relaxed">
                    <span class="material-icons-round text-sm">info</span>
                    OTP sent to your new email. Enter it to verify.
                </div>

                <div class="hidden text-xs font-bold text-indigo-600 flex items-center gap-1" id="otpTimer">
                    <span class="material-icons-round text-sm">timer</span>
                    Code expires in <span id="countdown">01:00</span>
                </div>

                <div class="flex flex-col gap-2 pt-2">
                    <button id="sendOtpBtn" class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-all" onclick="submitEmailChange()">Send OTP</button>
                    <button id="verifyOtpBtn" class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-all hidden" onclick="verifyEmailOtp()">Verify & Update</button>
                    <button class="w-full py-3 text-slate-500 font-bold hover:bg-slate-50 rounded-xl transition-all" onclick="closeEmailModal()">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-[100] bg-slate-900 text-white px-6 py-3 rounded-xl shadow-xl text-sm font-medium opacity-0 translate-y-4 transition-all duration-300 pointer-events-none" id="toast"></div>

    <script>
        function showToast(msg) {
            const toast = document.getElementById("toast");
            toast.innerText = msg;
            toast.classList.add("opacity-100", "-translate-y-4");
            setTimeout(() => {
                toast.classList.remove("opacity-100", "-translate-y-4");
            }, 3000);
        }

        function previewPhoto(event) {
            const file = event.target.files[0];
            if (!file) return;
            if (file.size > 800 * 1024) {
                showToast("Image must be under 800KB");
                return;
            }
            const reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById("avatarImg").src = e.target.result;
            }
            reader.readAsDataURL(file);
        }

        function removePhoto() {
            document.getElementById("avatarImg").src = "/images/default-avatar.png";
            document.getElementById("profileImage").value = "";
            showToast("Profile image removed");
        }

        let pendingEmail = "";
        let otpTimer = null;
        let otpTimeRemaining = 60;

        function stopOtpCountdown() {
            if (otpTimer) {
                clearInterval(otpTimer);
                otpTimer = null;
            }
        }

        function startOtpCountdown() {
            stopOtpCountdown();
            otpTimeRemaining = 60;
            const countdownElement = document.getElementById("countdown");
            const timerElement = document.getElementById("otpTimer");
            timerElement.classList.remove("hidden");
            otpTimer = setInterval(() => {
                const minutes = Math.floor(otpTimeRemaining / 60);
                const seconds = otpTimeRemaining % 60;
                countdownElement.textContent = `${minutes.toString().padStart(2, "0")}:${seconds.toString().padStart(2, "0")}`;
                if (otpTimeRemaining <= 0) {
                    stopOtpCountdown();
                    countdownElement.textContent = "Expired";
                }
                otpTimeRemaining--;
            }, 1000);
        }

        function openEmailModal() {
            pendingEmail = "";
            document.getElementById("newEmail").value = "";
            document.getElementById("emailOtp").value = "";
            document.getElementById("emailOtp").classList.add("hidden");
            document.getElementById("verifyOtpBtn").classList.add("hidden");
            document.getElementById("otpHint").classList.add("hidden");
            document.getElementById("sendOtpBtn").classList.remove("hidden");
            document.getElementById("otpTimer").classList.add("hidden");
            stopOtpCountdown();
            document.getElementById("emailModal").classList.replace("hidden", "flex");
        }

        function closeEmailModal() {
            document.getElementById("emailModal").classList.replace("flex", "hidden");
            stopOtpCountdown();
        }

        async function submitEmailChange() {
            let email = document.getElementById("newEmail").value.trim();
            let regex=/^[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\.[A-Za-z]{2,}$/;
            if(!email) { showToast("Enter an email"); return; }
            if (!regex.test(email)) { showToast("Enter valid email"); return; }

            try {
                const response = await fetch("/change-email/request", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ email })
                });
                const result = await response.json();
                if (!response.ok || !result.success) {
                    showToast(result.message || "Unable to send OTP");
                    return;
                }
                pendingEmail = email;
                document.getElementById("emailOtp").classList.remove("hidden");
                document.getElementById("verifyOtpBtn").classList.remove("hidden");
                document.getElementById("sendOtpBtn").classList.add("hidden");
                document.getElementById("otpHint").classList.remove("hidden");
                startOtpCountdown();
                showToast(result.message || "OTP sent");
            } catch (error) {
                showToast("Network error while sending OTP");
            }
        }

        async function verifyEmailOtp() {
            const otp = document.getElementById("emailOtp").value.trim();
            if (!/^[0-9]{6}$/.test(otp)) { showToast("Enter a valid 6-digit OTP"); return; }
            try {
                const response = await fetch("/change-email/verify", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ otp })
                });
                const result = await response.json();
                if (!response.ok || !result.success) {
                    showToast(result.message || "OTP verification failed");
                    return;
                }
                document.getElementById("email").value = result.email || pendingEmail;
                closeEmailModal();
                showToast(result.message || "Email updated successfully");
            } catch (error) {
                showToast("Network error while verifying OTP");
            }
        }

        document.getElementById("editProfileForm").addEventListener("submit", function (e) {
            let name = document.getElementById("fullName").value.trim();
            let username = document.getElementById("displayName").value.trim();
            let phone = document.getElementById("phone").value.trim();
            let dob = document.getElementById("dob").value;
            let image = document.getElementById("profileImage").files[0];

            if (!/^[A-Za-z ]{3,30}$/.test(name)) { showToast("Name must contain only letters"); e.preventDefault(); return; }
            if (username && !/^[a-zA-Z0-9_]{3,20}$/.test(username)) { showToast("Display name invalid"); e.preventDefault(); return; }
            if (phone && !/^[0-9]{10}$/.test(phone)) { showToast("Phone must be 10 digits"); e.preventDefault(); return; }
            if (dob && new Date(dob) > new Date()) { showToast("DOB cannot be future"); e.preventDefault(); return; }
        });

        function cancelEdit() {
            if (confirm("Discard changes?")) { window.location.href = "/profile"; }
        }

        const msg = <%- JSON.stringify(typeof msg !== "undefined" ? msg : "") %>;
        if (msg) { showToast(msg); }
    </script>

</body>
</html>