<!-- views/partials/admin-nav-links.ejs -->
<div x-data="{ 
    counts: { orders: 0, returns: 0, support: 0 },
    async fetchCounts() {
        try {
            const res = await fetch('/admin/api/sidebar-counts');
            const data = await res.json();
            if (data.success) this.counts = data.counts;
        } catch (err) { console.error('Sidebar counts error:', err); }
    }
}" x-init="fetchCounts(); window.addEventListener('new-notification', () => fetchCounts())">
    <style>
        @keyframes pulse-badge {
            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 106, 0, 0.4); }
            70% { transform: scale(1.1); box-shadow: 0 0 0 6px rgba(255, 106, 0, 0); }
            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 106, 0, 0); }
        }
        .badge-pulse { animation: pulse-badge 2s infinite; }
    </style>
    
    <div class="px-6 mb-6">
        <p class="text-[10px] uppercase tracking-[0.25em] text-white/20 font-black mb-4 font-display">Management</p>
        <div class="space-y-1.5">
            <!-- Dashboard -->
            <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm group transition-all <%= typeof title !== 'undefined' && title === 'Admin Dashboard' ? 'bg-white/10 text-white font-medium' : 'text-white/40 hover:text-white' %>">
                <svg class="w-4 h-4 transition-colors duration-200 <%= typeof title !== 'undefined' && title === 'Admin Dashboard' ? 'text-accent' : 'text-white/40 group-hover:text-white' %>" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
                </svg>
                Dashboard
            </a>
            
            <!-- Catalog -->
            <div x-data="{ open: <%= typeof title !== 'undefined' && ['Product Management', 'Category Management', 'Brand Management'].includes(title) ? 'true' : 'false' %> }">
                <button @click="open = !open" 
                        class="w-full flex items-center justify-between px-4 py-2.5 text-sm nav-item rounded-sm transition-colors group">
                    <div class="flex items-center gap-3 font-display">
                        <% const isCatalogActive = typeof title !== 'undefined' && ['Product Management', 'Category Management', 'Brand Management'].includes(title); %>
                        <svg class="w-4 h-4 transition-colors duration-200 <%= isCatalogActive ? 'text-accent' : 'text-white/40 group-hover:text-white' %>" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
                        </svg>
                        <span class="<%= isCatalogActive ? 'text-white font-medium' : 'text-white/40 group-hover:text-white' %>">Catalog</span>
                    </div>
                    <svg class="w-3 h-3 transition-transform duration-300 opacity-30 group-hover:opacity-100 text-white" 
                         :class="open ? 'rotate-180' : ''" 
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button>
                
                <div x-show="open" 
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 -translate-y-2"
                     x-transition:enter-end="opacity-100 translate-y-0"
                     class="mt-1 ml-4 pl-4 border-l border-white/5 space-y-1">
                    <a href="/admin/productManagement" class="block px-4 py-2 text-[11px] font-medium transition-all <%= typeof title !== 'undefined' && title === 'Product Management' ? 'text-white border-l-2 border-accent -ml-[17px] pl-[15px]' : 'text-white/40 hover:text-white' %>">
                        Products
                    </a>
                    <a href="/admin/categories" class="block px-4 py-2 text-[11px] font-medium transition-all <%= typeof title !== 'undefined' && title === 'Category Management' ? 'text-white border-l-2 border-accent -ml-[17px] pl-[15px]' : 'text-white/40 hover:text-white' %>">
                        Categories
                    </a>
                </div>
            </div>

            <!-- Orders -->
            <a href="/admin/orders" class="flex items-center justify-between px-4 py-2.5 text-sm nav-item rounded-sm group transition-all <%= typeof title !== 'undefined' && title === 'Orders' ? 'bg-white/10 text-white font-medium' : 'text-white/40 hover:text-white' %>">
                <div class="flex items-center gap-3">
                    <% const isOrdersActive = typeof title !== 'undefined' && title === 'Orders'; %>
                    <svg class="w-4 h-4 transition-colors duration-200 <%= isOrdersActive ? 'text-accent' : 'text-white/40 group-hover:text-white' %>" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0z" />
                    </svg>
                    <span>Orders</span>
                </div>
                <template x-if="counts.orders > 0">
                    <span class="w-5 h-5 rounded-full bg-accent text-black text-[10px] font-black flex items-center justify-center shadow-[0_0_15px_rgba(255,106,0,0.4)] ring-2 ring-black badge-pulse" x-text="counts.orders"></span>
                </template>
            </a>

            <!-- Returns -->
            <a href="/admin/returns" class="flex items-center justify-between px-4 py-2.5 text-sm nav-item rounded-sm group transition-all <%= typeof title !== 'undefined' && title === 'Return Management' ? 'bg-white/10 text-white font-medium' : 'text-white/40 hover:text-white' %>">
                <div class="flex items-center gap-3">
                    <% const isReturnsActive = typeof title !== 'undefined' && title === 'Return Management'; %>
                    <svg class="w-4 h-4 transition-colors duration-200 <%= isReturnsActive ? 'text-accent' : 'text-white/40 group-hover:text-white' %>" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
                    </svg>
                    <span>Returns</span>
                </div>
                <template x-if="counts.returns > 0">
                    <span class="w-5 h-5 rounded-full bg-status-warning text-black text-[10px] font-black flex items-center justify-center shadow-[0_0_15px_rgba(255,193,7,0.4)] ring-2 ring-black badge-pulse" x-text="counts.returns"></span>
                </template>
            </a>

            <!-- Customers -->
            <a href="/admin/customers" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm group transition-all <%= typeof title !== 'undefined' && title === 'Customers' ? 'bg-white/10 text-white font-medium' : 'text-white/40 hover:text-white' %>">
                <% const isCustomersActive = typeof title !== 'undefined' && title === 'Customers'; %>
                <svg class="w-4 h-4 transition-colors duration-200 <%= isCustomersActive ? 'text-accent' : 'text-white/40 group-hover:text-white' %>" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0z" />
                </svg>
                Customers
            </a>
            
            <!-- Sales Report -->
            <a href="/admin/sales-report" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm group transition-all <%= typeof title !== 'undefined' && title === 'Sales Report' ? 'bg-white/10 text-white font-medium' : 'text-white/40 hover:text-white' %>">
                <% const isSalesActive = typeof title !== 'undefined' && title === 'Sales Report'; %>
                <svg class="w-4 h-4 transition-colors duration-200 <%= isSalesActive ? 'text-accent' : 'text-white/40 group-hover:text-white' %>" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
                </svg>
                Sales Report
            </a>
        </div>
    </div>

    <div class="px-6 mb-6">
        <p class="text-[10px] uppercase tracking-[0.25em] text-white/20 font-black mb-4 font-display">Marketing</p>
        <div class="space-y-1.5">
            <!-- Coupons -->
            <a href="/admin/marketing/coupons" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm group transition-all <%= typeof title !== 'undefined' && title === 'Coupons' ? 'bg-white/10 text-white font-medium' : 'text-white/40 hover:text-white' %>">
                <% const isCouponsActive = typeof title !== 'undefined' && title === 'Coupons'; %>
                <svg class="w-4 h-4 transition-colors duration-200 <%= isCouponsActive ? 'text-accent' : 'text-white/40 group-hover:text-white' %>" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-12h12c.621 0 1.125.504 1.125 1.125V8.25a1.5 1.5 0 0 0-1.5 1.5 1.5 1.5 0 0 0 1.5 1.5v1.5a1.5 1.5 0 0 0-1.5 1.5 1.5 1.5 0 0 0 1.5 1.5v1.5c0 .621-.504 1.125-1.125 1.125H7.5c-.621 0-1.125-.504-1.125-1.125V16.5a1.5 1.5 0 0 0 1.5-1.5 1.5 1.5 0 0 0-1.5-1.5v-1.5a1.5 1.5 0 0 0 1.5-1.5 1.5 1.5 0 0 0-1.5-1.5V7.125C6.375 6.621 6.879 6 7.5 6z" />
                </svg>
                Coupons
            </a>

            <!-- Banners -->
            <a href="/admin/marketing/banners" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm group transition-all <%= typeof title !== 'undefined' && title === 'Banners' ? 'bg-white/10 text-white font-medium' : 'text-white/40 hover:text-white' %>">
                <% const isBannersActive = typeof title !== 'undefined' && title === 'Banners'; %>
                <svg class="w-4 h-4 transition-colors duration-200 <%= isBannersActive ? 'text-accent' : 'text-white/40 group-hover:text-white' %>" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0z" />
                </svg>
                Banners
            </a>

            <!-- Offers -->
            <a href="/admin/marketing/offers" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm group transition-all <%= typeof title !== 'undefined' && title === 'Offer Management' ? 'bg-white/10 text-white font-medium' : 'text-white/40 hover:text-white' %>">
                <% const isOffersActive = typeof title !== 'undefined' && title === 'Offer Management'; %>
                <svg class="w-4 h-4 transition-colors duration-200 <%= isOffersActive ? 'text-accent' : 'text-white/40 group-hover:text-white' %>" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581a2.25 2.25 0 0 0 3.182 0l5.174-5.173a2.25 2.25 0 0 0 0-3.181L12.01 3.659A2.25 2.25 0 0 0 10.419 3H9.568zm.052 4.25a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0z" />
                </svg>
                Offers
            </a>
        </div>
    </div>

    <div class="px-6 mb-6">
        <p class="text-[10px] uppercase tracking-[0.25em] text-white/20 font-black mb-4 font-display">System</p>
        <div class="space-y-1.5">
            <!-- Settings -->
            <a href="/admin/settings/general" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm group transition-all <%= typeof title !== 'undefined' && title === 'Settings' ? 'bg-white/10 text-white font-medium' : 'text-white/40 hover:text-white' %>">
                <% const isSettingsActive = typeof title !== 'undefined' && title === 'Settings'; %>
                <svg class="w-4 h-4 transition-colors duration-200 <%= isSettingsActive ? 'text-accent' : 'text-white/40 group-hover:text-white' %>" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.43l-1.003.828c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.43l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 0 1 0-.255c.007-.378-.138-.75-.43-.991l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.645-.869l.214-1.28z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" />
                </svg>
                Settings
            </a>

            <!-- Support -->
            <a href="/admin/support" class="flex items-center justify-between px-4 py-2.5 text-sm nav-item rounded-sm group transition-all <%= typeof title !== 'undefined' && title === 'Support' ? 'bg-white/10 text-white font-medium' : 'text-white/40 hover:text-white' %>">
                <div class="flex items-center gap-3">
                    <% const isSupportActive = typeof title !== 'undefined' && title === 'Support'; %>
                    <svg class="w-4 h-4 transition-colors duration-200 <%= isSupportActive ? 'text-accent' : 'text-white/40 group-hover:text-white' %>" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                    <span>Support</span>
                </div>
                <template x-if="counts.support > 0">
                    <span class="w-5 h-5 rounded-full bg-accent text-black text-[10px] font-black flex items-center justify-center shadow-[0_0_15px_rgba(255,106,0,0.4)] ring-2 ring-black badge-pulse" x-text="counts.support"></span>
                </template>
            </a>
        </div>
    </div>
</div>
