<!-- views/partials/tracker-render.ejs -->
<% 
// Calculate active stages
let activeIndex = -1;
for(let i=stages.length-1; i>=0; i--) {
    if(stages[i].active) { activeIndex = i; break; }
}

const totalStages = stages.length;
// Side offset to center the dots within their flex-1 containers
const sideOffset = (100 / totalStages) / 2;
const totalLineWidth = 100 - (sideOffset * 2);
%>

<div class="relative py-4">
    <!-- Connecting Line Base (Grey) -->
    <div class="absolute top-6 left-[<%= sideOffset %>%] right-[<%= sideOffset %>%] h-0.5 bg-white/5 z-0 hidden sm:block"></div>
    
    <!-- Active Connecting Line (Accent) -->
    <% if (activeIndex > 0) { %>
        <div class="absolute top-6 left-[<%= sideOffset %>%] h-0.5 bg-accent z-0 hidden sm:block transition-all duration-1000 shadow-[0_0_15px_rgba(255,106,0,0.4)]" 
             style="width: <%= (activeIndex / (totalStages - 1)) * totalLineWidth %>%;"></div>
    <% } %>

    <div class="flex flex-col sm:flex-row justify-between relative z-10 w-full">
        <% stages.forEach((stage, index) => { %>
            <div class="flex flex-row sm:flex-col items-start sm:items-center flex-1 relative group mb-8 sm:mb-0">
                
                <!-- Vertical line for mobile -->
                <% if (index !== stages.length - 1) { %>
                    <div class="absolute left-6 top-12 bottom-[-2rem] w-[1px] bg-white/5 sm:hidden z-0"></div>
                    <% if (stage.active && stages[index+1].active) { %>
                        <div class="absolute left-6 top-12 bottom-[-2rem] w-[1px] bg-accent sm:hidden z-0 shadow-[0_0_10px_rgba(255,106,0,0.3)]"></div>
                    <% } %>
                <% } %>

                <!-- Dot / Icon -->
                <div class="w-12 h-12 rounded-full border-[4px] border-[#0a0a0a] flex items-center justify-center flex-shrink-0 <%= stage.active ? (stage.color ? 'bg-status-danger' : 'bg-accent shadow-[0_0_20px_rgba(255,106,0,0.3)]') : 'bg-[#1a1a1a]' %> sm:mb-6 transition-all duration-300 group-hover:scale-110 z-10 mr-6 sm:mr-0">
                    <% if(stage.active) { %>
                        <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                    <% } else { %>
                        <div class="w-2 h-2 bg-white/10 rounded-full"></div>
                    <% } %>
                </div>
                
                <!-- Content -->
                <div class="flex flex-col sm:items-center text-left sm:text-center w-full px-2">
                    <p class="<%= stage.active ? (stage.color || 'text-white') : 'text-white/30' %> text-[10px] font-black uppercase tracking-[0.2em] mb-2 transition-colors"><%= stage.name %></p>
                    <p class="text-white/20 text-[9px] hidden sm:block mb-3 font-bold uppercase tracking-widest leading-tight h-8"><%= stage.desc %></p>
                    
                    <% if (stage.date && stage.active) { %>
                        <div class="inline-flex flex-col items-center">
                            <span class="px-2 py-1 bg-accent/5 border border-accent/10 rounded-sm text-accent text-[9px] font-mono font-bold tracking-tighter">
                                <%= new Date(stage.date).toLocaleDateString('en-IN', { day: '2-digit', month: '2-digit', year: 'numeric' }) %>
                            </span>
                        </div>
                    <% } %>
                </div>
            </div>
        <% }) %>
    </div>
</div>
