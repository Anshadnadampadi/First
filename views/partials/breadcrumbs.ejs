<!-- views/partials/breadcrumbs.ejs -->
<% if (locals.breadcrumbs && breadcrumbs.length > 0) { %>
<div class="breadcrumbs-container <%= typeof isAdmin !== 'undefined' && isAdmin ? 'px-8 py-6' : 'px-4 py-8 max-w-7xl mx-auto w-full' %>">
    <nav aria-label="Breadcrumb" class="overflow-x-auto no-scrollbar">
        <ol class="flex items-center gap-3 whitespace-nowrap list-none m-0 p-0 font-mono text-[10px] font-bold tracking-[0.2em] uppercase">
            <li class="flex items-center">
                <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                    <a href="/admin/dashboard" class="flex items-center gap-2 text-white/30 hover:text-accent transition-all duration-300 group">
                        <svg class="w-3.5 h-3.5 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                        </svg>
                        <span>HOME</span>
                    </a>
                <% } else { %>
                    <a href="/" class="flex items-center gap-2 text-white/30 hover:text-white transition-all duration-300">
                        <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                        </svg>
                        <span>HOME</span>
                    </a>
                <% } %>
            </li>
            
            <% breadcrumbs.forEach((crumb, index) => { %>
            <li class="flex items-center gap-3">
                <span class="text-white/10 font-normal text-xs select-none">/</span>
                <% if (index === breadcrumbs.length - 1) { %>
                    <span class="text-white relative select-none">
                        <%= crumb.label %>
                        <span class="absolute -bottom-1 left-0 w-full h-[1px] bg-accent/30"></span>
                    </span>
                <% } else { %>
                    <a href="<%= crumb.url %>" class="text-white/30 hover:text-white transition-all duration-300">
                        <%= crumb.label %>
                    </a>
                <% } %>
            </li>
            <% }) %>
        </ol>
    </nav>
</div>
<% } %>

<style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
