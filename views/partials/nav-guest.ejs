<!-- views/partials/nav-guest.ejs -->
<nav x-data="{ mobileMenu: false }" class="h-20 glass border-b border-black-border sticky top-0 z-40 flex items-center justify-between px-6 lg:px-12">
    <!-- Logo -->
    <div class="flex items-center gap-8">
        <a href="/" class="text-white font-bold tracking-widest text-xl">STARZO</a>

        <!-- Desktop Menu -->
        <div class="hidden lg:flex items-center gap-8">
            <a href="/products"
                class="text-[11px] font-semibold tracking-widest text-text-secondary hover:text-white transition-colors uppercase">All
                Phones</a>
            
            <a href="/deals"
                class="text-[11px] font-semibold tracking-widest text-text-secondary hover:text-white transition-colors uppercase">Deals</a>
            <a href="/support"
                class="text-[11px] font-semibold tracking-widest text-text-secondary hover:text-white transition-colors uppercase">Support</a>
        </div>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-6">
        <!-- Search -->
        <div class="relative group hidden md:block">
            <form action="/search" method="GET">
                <input type="text" name="q" placeholder="Search..."
                    class="bg-white/5 border border-white/10 rounded-sm px-4 py-2 text-xs text-white focus:outline-none focus:border-accent/50 w-48 transition-all focus:w-64">
            </form>
        </div>

        <!-- Tools -->
        <div class="flex items-center gap-6">
            <a href="/wishlist" class="text-white/60 hover:text-white transition-colors relative" title="Wishlist">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z">
                    </path>
                </svg>
                <span id="wishlist-badge"
                    class="absolute -top-2 -right-2 bg-accent text-black text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center">
                    0
                </span>
            </a>

            <a href="/cart" class="text-white/60 hover:text-white transition-colors relative" title="Cart">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                </svg>
                <span id="cart-badge"
                    class="absolute -top-2 -right-2 bg-accent text-black text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center">
                    0
                </span>
            </a>
        </div>

        <!-- Guest Actions -->
        <div class="hidden lg:flex items-center gap-4">
            <a href="/auth/login"
                class="text-[11px] font-bold tracking-[0.2em] text-white/60 hover:text-white transition-colors uppercase">Login</a>
            <a href="/auth/register"
                class="bg-white text-black text-[10px] font-bold tracking-[0.2em] px-6 py-2.5 uppercase hover:bg-accent transition-all btn-press">
                Register
            </a>
        </div>

        <!-- Modern Mobile Toggle -->
        <button @click="mobileMenu = true" 
                class="lg:hidden w-10 h-10 flex items-center justify-center rounded-sm bg-white/5 border border-white/10 text-white hover:bg-white/10 transition-all active:scale-95">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8h16M4 16h16"></path>
            </svg>
        </button>
    </div>

    <!-- Modern Glass Mobile Menu Drawer (Guest) -->
    <div x-show="mobileMenu" 
         x-cloak
         class="fixed inset-0 z-[100] lg:hidden">
        
        <!-- Ultra-Glass Backdrop -->
        <div x-show="mobileMenu"
             x-transition:enter="transition ease-out duration-500"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition ease-in duration-400"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             @click="mobileMenu = false"
             class="absolute inset-0 bg-black/40 backdrop-blur-md"></div>
        
        <!-- Glass Drawer -->
        <div x-show="mobileMenu"
             x-transition:enter="transition ease-out duration-500 cubic-bezier(0.32, 0.72, 0, 1)"
             x-transition:enter-start="translate-x-full"
             x-transition:enter-end="translate-x-0"
             x-transition:leave="transition ease-in duration-400 cubic-bezier(0.32, 0.72, 0, 1)"
             x-transition:leave-start="translate-x-0"
             x-transition:leave-end="translate-x-full"
             class="absolute right-0 top-0 bottom-0 w-[85%] max-w-sm bg-black/60 backdrop-blur-2xl border-l border-white/10 p-8 flex flex-col shadow-[-20px_0_50px_rgba(0,0,0,0.5)]">
            
            <!-- Animated Background Gradient -->
            <div class="absolute top-0 right-0 w-64 h-64 bg-accent/10 rounded-full blur-[100px] -z-10 animate-pulse"></div>

            <div class="flex justify-between items-center mb-12">
                <span class="text-white font-black tracking-[0.25em] text-xl">STARZO<span class="text-accent text-[10px] ml-1 uppercase">Guest</span></span>
                <button @click="mobileMenu = false" class="text-white/40 hover:text-white p-2 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <div class="flex flex-col gap-8 mb-12">
                <div class="space-y-6">
                    <p class="text-[9px] font-black uppercase tracking-[0.3em] text-white/30">Explore</p>
                    <a href="/products" @click="mobileMenu = false" class="text-2xl font-black tracking-tighter text-white uppercase italic hover:text-accent transition-colors flex justify-between items-center group">
                        All Phones
                        <i class="fas fa-arrow-right text-xs opacity-0 group-hover:opacity-100 transition-all -translate-x-4 group-hover:translate-x-0"></i>
                    </a>
                    <a href="/deals" @click="mobileMenu = false" class="text-2xl font-black tracking-tighter text-white uppercase italic hover:text-accent transition-colors flex justify-between items-center group">
                        Deals
                        <i class="fas fa-arrow-right text-xs opacity-0 group-hover:opacity-100 transition-all -translate-x-4 group-hover:translate-x-0"></i>
                    </a>
                    <a href="/support" @click="mobileMenu = false" class="text-2xl font-black tracking-tighter text-white uppercase italic hover:text-accent transition-colors flex justify-between items-center group">
                        Support
                        <i class="fas fa-arrow-right text-xs opacity-0 group-hover:opacity-100 transition-all -translate-x-4 group-hover:translate-x-0"></i>
                    </a>
                </div>
            </div>

            <div class="mt-auto pt-8 border-t border-white/5 space-y-4">
                <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
                <a href="/auth/login" class="block w-full bg-white text-black text-center py-4 text-[10px] font-black uppercase tracking-[0.3em] hover:bg-accent transition-all shadow-[0_0_20px_rgba(255,255,255,0.1)]">Sign In</a>
                <a href="/auth/register" class="block w-full border border-white/20 text-white text-center py-4 text-[10px] font-black uppercase tracking-[0.3em] hover:border-white transition-all">Create Account</a>
            </div>
        </div>
    </div>
</nav>