<!-- views/partials/confirm-modal.ejs -->
<script>
/**
 * DEPRECATED: This partial is no longer used.
 * Redirection logic stays here temporarily to prevent breakages if any file still includes it.
 */
document.addEventListener('alpine:init', () => {
    // If someone calls window.confirmAction, ios-alert.ejs handles it.
    // If someone dispatches 'show-confirm', we redirect it to 'show-ios-alert'.
    window.addEventListener('show-confirm', (e) => {
        window.dispatchEvent(new CustomEvent('show-ios-alert', { detail: e.detail }));
    });
});
</script>
