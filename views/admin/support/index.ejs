<%- contentFor('body') %>

<div class="space-y-10">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <h1 class="text-3xl font-black tracking-tight uppercase text-white mb-2">SUPPORT COMMAND.</h1>
            <p class="text-white/40 text-[10px] tracking-[0.2em] font-bold uppercase">Resolve customer inquiries and technical issues</p>
        </div>
        
        <!-- Search and Filters -->
        <div class="flex flex-wrap gap-4 w-full md:w-auto">
            <form action="/admin/support" method="GET" class="flex flex-wrap gap-3 w-full md:w-auto">
                <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Search Ticket ID or Subject..."
                    class="bg-black border border-white/10 px-6 py-3 text-[10px] text-white uppercase tracking-widest focus:outline-none focus:border-accent transition-colors w-full md:w-64 font-bold">
                
                <select name="status" class="bg-black border border-white/10 px-4 py-3 text-[10px] text-white uppercase tracking-widest focus:outline-none focus:border-accent transition-colors font-bold">
                    <option value="">All Status</option>
                    <option value="Open" <%= filters.status === 'Open' ? 'selected' : '' %>>Open</option>
                    <option value="In-Progress" <%= filters.status === 'In-Progress' ? 'selected' : '' %>>In-Progress</option>
                    <option value="Resolved" <%= filters.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                    <option value="Closed" <%= filters.status === 'Closed' ? 'selected' : '' %>>Closed</option>
                </select>

                <button type="submit" class="px-6 py-3 bg-white text-black text-[10px] font-black uppercase tracking-widest hover:bg-accent transition-all">Filter</button>
                <% if (Object.values(filters).some(f => f)) { %>
                    <a href="/admin/support" class="px-6 py-3 border border-white/10 text-white/40 text-[10px] font-black uppercase tracking-widest hover:text-white transition-all">Reset</a>
                <% } %>
            </form>
        </div>
    </div>

    <!-- Active Tickets Table -->
    <div class="bg-black-surface border border-white/5 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-white/5 bg-white/[0.02]">
                        <th class="p-6 text-[9px] font-black uppercase tracking-widest text-white/20">Ticket Info</th>
                        <th class="p-6 text-[9px] font-black uppercase tracking-widest text-white/20">Customer</th>
                        <th class="p-6 text-[9px] font-black uppercase tracking-widest text-white/20 text-center">Priority</th>
                        <th class="p-6 text-[9px] font-black uppercase tracking-widest text-white/20 text-center">Status</th>
                        <th class="p-6 text-[9px] font-black uppercase tracking-widest text-white/20 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <% if (tickets.length > 0) { %>
                        <% tickets.forEach(ticket => { %>
                            <tr class="group hover:bg-white/[0.01] transition-colors">
                                <td class="p-6">
                                    <div class="flex items-center gap-4">
                                        <div class="w-1 h-10 <%= ticket.priority === 'High' || ticket.priority === 'Urgent' ? 'bg-status-danger' : 'bg-status-info' %>"></div>
                                        <div>
                                            <div class="flex items-center gap-3 mb-1">
                                                <span class="text-[10px] font-mono text-accent font-bold tracking-widest"><%= ticket.ticketId %></span>
                                                <span class="text-[8px] text-white/20 uppercase tracking-widest font-bold"><%= ticket.category %></span>
                                            </div>
                                            <h4 class="text-white text-xs font-bold uppercase tracking-wide group-hover:text-white transition-colors"><%= ticket.subject %></h4>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-6">
                                    <div class="space-y-1">
                                        <p class="text-white text-[10px] font-bold uppercase"><%= ticket.user.name %></p>
                                        <p class="text-white/30 text-[9px] font-mono tracking-tighter"><%= ticket.user.email %></p>
                                    </div>
                                </td>
                                <td class="p-6 text-center">
                                    <span class="px-3 py-1 rounded-sm text-[8px] font-black uppercase tracking-widest 
                                        <%= ticket.priority === 'High' || ticket.priority === 'Urgent' ? 'bg-status-danger/10 text-status-danger border border-status-danger/20' : 
                                            ticket.priority === 'Medium' ? 'bg-status-warning/10 text-status-warning border border-status-warning/20' :
                                            'bg-status-info/10 text-status-info border border-status-info/20' %>">
                                        <%= ticket.priority %>
                                    </span>
                                </td>
                                <td class="p-6 text-center">
                                    <div class="flex justify-center">
                                        <%- include('../../partials/status-badge', { status: ticket.status }) %>
                                    </div>
                                </td>
                                <td class="p-6 text-right">
                                    <a href="/admin/support/ticket/<%= ticket._id %>" 
                                        class="inline-block px-6 py-3 bg-white/5 border border-white/10 text-white text-[9px] font-black tracking-widest uppercase hover:bg-white hover:text-black transition-all">
                                        Handle
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="p-20 text-center">
                                <div class="flex flex-col items-center gap-4">
                                    <p class="text-white/20 text-[10px] font-bold tracking-widest uppercase">No support tickets found matching your encryption parameters.</p>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
        <div class="flex justify-center mt-8">
            <div class="flex gap-2">
                <% for(let i = 1; i <= totalPages; i++) { %>
                    <a href="/admin/support?page=<%= i %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.search ? '&search=' + filters.search : '' %>" 
                        class="w-10 h-10 flex items-center justify-center border <%= currentPage === i ? 'bg-white text-black border-white' : 'border-white/10 text-white/40 hover:border-white/30' %> text-[10px] font-black transition-all">
                        <%= i %>
                    </a>
                <% } %>
            </div>
        </div>
    <% } %>
</div>
