<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Icons -->
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet">

  <!-- Font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Chart JS -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    :root {
      --primary: #50C878;
      --bg-dark: #0A1A14;
      --surface-dark: #11261E;
      --border-dark: #1e3d31;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-dark);
      color: white;
    }

    /* Sidebar */
    .sidebar {
      width: 260px;
      height: 100vh;
      position: fixed;
      background: var(--bg-dark);
      border-right: 1px solid var(--border-dark);
    }

    .sidebar a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 20px;
      text-decoration: none;
      color: #9fb3aa;
      transition: .3s;
    }

    .sidebar a:hover {
      color: var(--primary);
      background: rgba(80, 200, 120, .05);
    }

    .sidebar .active {
      background: rgba(80, 200, 120, .1);
      color: var(--primary);
      border-radius: 10px;
    }

    /* Main */
    .main-content {
      margin-left: 260px;
      padding: 40px;
    }

    /* Glass */
    .glass-card {
      background: rgba(17, 38, 30, .6);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(80, 200, 120, .2);
      border-radius: 16px;
    }

    /* Table */
    .custom-table th,
    .custom-table td {
      background: transparent !important;
      border-color: var(--border-dark);
      color: white;
    }

    .custom-table thead {
      color: #6c757d;
      font-size: 12px;
      text-transform: uppercase;
    }

    .progress {
      height: 6px;
      background: #1b3a2d;
    }

    .progress-bar {
      background: var(--primary);
    }

    /* Responsive Styles */
    @media (max-width: 768px) {
      .sidebar {
        transform: translateX(-100%);
        transition: transform 0.3s ease;
        z-index: 1050;
      }

      .sidebar.open {
        transform: translateX(0);
      }

      .main-content {
        margin-left: 0;
        padding: 15px;
      }

      .mobile-nav-toggle {
        background: transparent;
        border: none;
        color: white;
        padding: 0;
      }

      .glass-card {
        overflow-x: auto;
      }

      .custom-table {
        min-width: 500px;
      }

      .d-flex.justify-content-between.align-items-center.mb-4 {
        flex-direction: column;
        align-items: flex-start !important;
        gap: 15px;
      }
    }
  </style>
</head>

<body>

  <!-- Sidebar -->
  <div class="sidebar p-3 d-flex flex-column">
    <h4 class="fw-bold mb-4">
      <span class="material-icons-outlined">diamond</span>
      Starzo
    </h4>

    <a href="#" class="active"><span class="material-icons-outlined">dashboard</span>Dashboard</a>
    <a href="#"><span class="material-icons-outlined">shopping_cart</span>Orders</a>
    <a href="#"><span class="material-icons-outlined">inventory_2</span>Products</a>
    <a href="#"><span class="material-icons-outlined">category</span>Categories</a>
    <a href="#"><span class="material-icons-outlined">confirmation_number</span>Coupons</a>
    <a href="/admin/management"><span class="material-icons-outlined">people</span>Customers</a>

    <div class="mt-auto pt-3 border-top border-secondary">
      <small>Mohammad Anshad</small><br>
      <small class="text-secondary">Admin Account</small>
    </div>
  </div>

  <!-- Main -->
  <div class="main-content">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div class="d-flex align-items-center gap-3">
        <button class="mobile-nav-toggle d-md-none"
          onclick="document.querySelector('.sidebar').classList.toggle('open')">
          <span class="material-icons-outlined">menu</span>
        </button>
        <div>
          <h3 class="fw-bold mb-0">Admin Dashboard</h3>
          <small class="text-secondary">Welcome back, here's what's happening today.</small>
        </div>
      </div>

      <button class="btn btn-success d-flex align-items-center gap-2">
        <span class="material-icons-outlined">assessment</span>
        View Sales Report
      </button>
    </div>

    <!-- Stats -->
    <div class="row g-4 mb-4">
      <div class="col-md-3">
        <div class="glass-card p-4">
          <small class="text-secondary">Total Revenue</small>
          <h4 class="fw-bold mt-2">$45,231.89</h4>
          <small class="text-success">+20% this month</small>
        </div>
      </div>
      <div class="col-md-3">
        <div class="glass-card p-4">
          <small class="text-secondary">Total Orders</small>
          <h4 class="fw-bold mt-2">2,350</h4>
          <small class="text-success">+15%</small>
        </div>
      </div>
      <div class="col-md-3">
        <div class="glass-card p-4">
          <small class="text-secondary">Pending Orders</small>
          <h4 class="fw-bold mt-2">48</h4>
          <small class="text-warning">Needs Attention</small>
        </div>
      </div>
      <div class="col-md-3">
        <div class="glass-card p-4">
          <small class="text-secondary">Active Users</small>
          <h4 class="fw-bold mt-2">12,234</h4>
          <small class="text-success">+7%</small>
        </div>
      </div>
    </div>

    <!-- Revenue Chart -->
    <div class="row g-4 mb-4">
      <div class="col-lg-8">
        <div class="glass-card p-4">
          <h5 class="fw-bold mb-3">Revenue Overview</h5>
          <canvas id="revenueChart" height="120"></canvas>
        </div>
      </div>

      <!-- Recent Sales -->
      <div class="col-lg-4">
        <div class="glass-card p-4">
          <h5 class="fw-bold mb-3">Recent Sales</h5>

          <div class="d-flex justify-content-between mb-3">
            <span>Olivia Martin</span>
            <strong>$1,999</strong>
          </div>
          <div class="d-flex justify-content-between mb-3">
            <span>Jackson Lee</span>
            <strong>$39</strong>
          </div>
          <div class="d-flex justify-content-between mb-3">
            <span>Isabella Nguyen</span>
            <strong>$299</strong>
          </div>
          <div class="d-flex justify-content-between">
            <span>William Chen</span>
            <strong>$1,999</strong>
          </div>

        </div>
      </div>
    </div>

    <!-- Products + Categories -->
    <div class="row g-4">
      <div class="col-lg-8">
        <div class="glass-card p-4">
          <h5 class="fw-bold mb-3">Top Trending Products</h5>

          <table class="table custom-table">
            <thead>
              <tr>
                <th>Product</th>
                <th>Category</th>
                <th class="text-end">Sales</th>
                <th class="text-end">Revenue</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Galaxy S23 Ultra</td>
                <td>Samsung</td>
                <td class="text-end">342</td>
                <td class="text-end">$1,995,390</td>
              </tr>
              <tr>
                <td>iPhone 17 Pro</td>
                <td>Apple</td>
                <td class="text-end">288</td>
                <td class="text-end">$999,988</td>
              </tr>
              <tr>
                <td>Redmi Note 13 Pro</td>
                <td>Xiaomi</td>
                <td class="text-end">245</td>
                <td class="text-end">$1,290,999</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Categories -->
      <div class="col-lg-4">
        <div class="glass-card p-4">
          <h5 class="fw-bold mb-3">Top Categories</h5>

          <p class="mb-1">Samsung 45%</p>
          <div class="progress mb-3">
            <div class="progress-bar" style="width:45%"></div>
          </div>

          <p class="mb-1">Xiaomi 28%</p>
          <div class="progress mb-3">
            <div class="progress-bar" style="width:28%"></div>
          </div>

          <p class="mb-1">Apple 15%</p>
          <div class="progress mb-3">
            <div class="progress-bar" style="width:15%"></div>
          </div>

          <p class="mb-1">Others 12%</p>
          <div class="progress">
            <div class="progress-bar" style="width:12%"></div>
          </div>

        </div>
      </div>
    </div>

  </div>

  <!-- Chart Script -->
  <script>
    const ctx = document.getElementById('revenueChart').getContext('2d');
    new Chart(ctx, {
      type: 'line',
      data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep'],
        datasets: [{
          label: 'Revenue',
          data: [200, 180, 190, 140, 145, 90, 80, 30, 20],
          borderColor: '#50C878',
          backgroundColor: 'rgba(80,200,120,.2)',
          tension: .4,
          fill: true
        }]
      },
      options: {
        plugins: { legend: { display: false } },
        scales: {
          x: { ticks: { color: '#aaa' } },
          y: { ticks: { color: '#aaa' } }
        }
      }
    });
  </script>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <!-- Query Path params -->
  <% if (typeof msg !=='undefined' ) { %>
    <script>
      Swal.fire({
        title: "<%=msg%>",
        text: "That thing is still around?",
        icon: "<%=icon%>",
        background: '#102a0f',
        color: '#DADACE',
      });

      const url = window.location.protocol + "//" + window.location.host + window.location.pathname;
      window.history.replaceState({ path: url }, '', url);

    </script>
    <% } %>

</body>

</html>