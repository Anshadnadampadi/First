<!-- views/admin/marketing/offers.ejs -->
<%- contentFor('body') %>

    <%- include('../../partials/toast') %>
    <div class="space-y-10" x-data="offerManager">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
            <div>
                <h1 class="text-3xl font-bold tracking-tight uppercase text-white mb-2">PROMOTIONAL OFFERS.</h1>
                <p class="text-white/40 text-[10px] tracking-[0.2em] font-bold uppercase">Configure Product and Category specific discounts</p>
            </div>
            <button @click="openCreateModal()"
                class="px-8 py-4 bg-white text-black text-[10px] font-bold tracking-widest uppercase hover:bg-accent transition-all btn-press shadow-[0_0_20px_rgba(255,255,255,0.1)] flex items-center gap-3">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"></path></svg>
                Create New Offer
            </button>
        </div>

        <!-- Filters & Tabs -->
        <div class="space-y-6">
            <div class="flex items-center gap-8 border-b border-white/5">
                <button @click="currentTab = 'live'" 
                    :class="currentTab === 'live' ? 'text-accent border-accent' : 'text-white/40 border-transparent hover:text-white'"
                    class="pb-4 text-[10px] font-bold tracking-[0.2em] uppercase border-b-2 transition-all">Live Offers <span class="ml-2 w-1.5 h-1.5 rounded-full bg-status-success inline-block"></span></button>
                <button @click="currentTab = 'archived'"
                    :class="currentTab === 'archived' ? 'text-accent border-accent' : 'text-white/40 border-transparent hover:text-white'"
                    class="pb-4 text-[10px] font-bold tracking-[0.2em] uppercase border-b-2 transition-all">Archived / Expired</button>
            </div>

            <div class="bg-black-surface border border-white/5 p-6 flex flex-col md:flex-row justify-between items-center gap-6">
                <div class="relative group w-full md:w-96">
                    <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none text-white/20">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                    <input type="text" x-model="search" placeholder="Search by offer name..." 
                           class="w-full bg-black border border-white/10 px-10 py-3 text-[10px] text-white placeholder:text-white/20 focus:border-accent focus:outline-none transition-all uppercase tracking-widest font-mono">
                </div>
                <div class="flex items-center gap-4 text-white/20 text-[10px] font-bold uppercase tracking-widest">
                    Total Results: <span class="text-white"><%= typeof totalOffers !== 'undefined' ? totalOffers : offers.length %></span>
                </div>
            </div>
        </div>

        <!-- Table View -->
        <div class="bg-black-surface border border-white/5 overflow-hidden shadow-2xl">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-white/[0.02] border-b border-white/5">
                        <th class="px-8 py-6 text-[9px] font-black tracking-[0.2em] uppercase text-white/30">Offer Name</th>
                        <th class="px-8 py-6 text-[9px] font-black tracking-[0.2em] uppercase text-white/30">Target</th>
                        <th class="px-8 py-6 text-[9px] font-black tracking-[0.2em] uppercase text-white/30">Discount</th>
                        <th class="px-8 py-6 text-[9px] font-black tracking-[0.2em] uppercase text-white/30">Timeline</th>
                        <th class="px-8 py-6 text-[9px] font-black tracking-[0.2em] uppercase text-white/30">Status</th>
                        <th class="px-8 py-6 text-[9px] font-black tracking-[0.2em] uppercase text-white/30 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <% offers.forEach(offer => { %>
                        <% 
                            const isExpired = new Date(offer.expiryDate) < new Date();
                        %>
                        <tr x-data="{ 
                            active: <%= offer.isActive %>,
                            async toggle() {
                                try {
                                    const res = await fetch(`/admin/marketing/offers/toggle/<%= offer._id %>`, { method: 'PATCH' });
                                    const data = await res.json();
                                    if (!data.success) {
                                        this.active = !this.active;
                                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: data.message || 'Failed to update', type: 'error' } }));
                                    } else {
                                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Status updated', type: 'success' } }));
                                    }
                                } catch (e) { 
                                    this.active = !this.active;
                                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Network error', type: 'error' } }));
                                }
                            }
                        }" class="hover:bg-white/[0.01] group"
                            x-show="((currentTab === 'live' && !<%= isExpired %>) || (currentTab === 'archived' && <%= isExpired %>)) && ('<%= offer.name %>'.toLowerCase().includes(search.toLowerCase()))">
                            <td class="px-8 py-8">
                                <span class="text-white text-sm font-bold uppercase tracking-tight"><%= offer.name %></span>
                                <p class="text-white/20 text-[8px] uppercase mt-1 tracking-widest"><%= offer.type %> Level</p>
                            </td>
                            <td class="px-8 py-8">
                                <div class="bg-white/5 border border-white/10 px-3 py-1.5 text-white/60 text-[10px] font-bold tracking-widest uppercase inline-block rounded-sm">
                                    <%= offer.type === 'Product' ? (offer.productId ? offer.productId.name : 'Unknown Product') : (offer.categoryId ? offer.categoryId.name : 'Unknown Category') %>
                                </div>
                            </td>
                            <td class="px-8 py-8">
                                <p class="text-white text-sm font-bold uppercase">
                                    <%= offer.discountType === 'percentage' ? offer.discountValue + '%' : '₹' + offer.discountValue.toLocaleString() %> Off
                                </p>
                            </td>
                            <td class="px-8 py-8">
                                <div class="flex flex-col">
                                    <span class="text-white text-[10px] font-bold uppercase tracking-widest">
                                        <%= new Date(offer.startDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }) %> - 
                                        <%= new Date(offer.expiryDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                    </span>
                                    <span class="text-white/20 text-[8px] uppercase tracking-tighter mt-1">Validity Period</span>
                                </div>
                            </td>
                            <td class="px-8 py-8">
                                <% if (isExpired) { %>
                                    <span class="px-3 py-1 bg-status-danger/10 text-status-danger text-[8px] font-bold uppercase tracking-widest border border-status-danger/20 rounded-full">Expired</span>
                                <% } else { %>
                                    <span x-show="!active" class="px-3 py-1 bg-white/5 text-white/40 text-[8px] font-bold uppercase tracking-widest border border-white/10 rounded-full">Inactive</span>
                                    <span x-show="active" class="px-3 py-1 bg-status-success/10 text-status-success text-[8px] font-bold uppercase tracking-widest border border-status-success/20 rounded-full">Active</span>
                                <% } %>
                            </td>
                            <td class="px-8 py-8 text-center align-middle">
                                <div class="flex items-center justify-center gap-6">
                                    <!-- Premium Toggle (Icon Movement Focused) -->
                                    <label class="relative inline-flex items-center cursor-pointer group">
                                        <input type="checkbox" class="absolute opacity-0" x-model="active" @change="toggle()">
                                        <div class="w-10 h-5 bg-white/5 rounded-full relative border border-white/10 transition-colors duration-300">
                                            <div class="absolute top-0.5 left-0.5 w-4 h-4 rounded-full transition-transform duration-500 ease-in-out shadow-[0_0_10px_rgba(0,0,0,0.5)]"
                                                 :class="active ? 'bg-accent' : 'bg-white/20'"
                                                 :style="{ transform: active ? 'translateX(20px)' : 'translateX(0)' }"></div>
                                        </div>
                                    </label>

                                    <button type="button" @click.prevent.stop="openEditModal('<%= offer._id %>', '<%= offer.name %>', '<%= offer.type %>', '<%= offer.discountType %>', <%= offer.discountValue %>, '<%= offer.productId ? offer.productId._id : `` %>', '<%= offer.categoryId ? offer.categoryId._id : `` %>', '<%= offer.startDate ? new Date(offer.startDate).toISOString().split(`T`)[0] : `` %>', '<%= offer.expiryDate ? new Date(offer.expiryDate).toISOString().split(`T`)[0] : `` %>')"
                                        class="text-white/40 hover:text-white transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                    </button>
                                    
                                    <button type="button" @click.prevent.stop="confirmDelete('<%= offer._id %>', '<%= offer.name %>')"
                                        class="text-white/20 hover:text-status-danger transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <% 
            let paginationQuery = '';
            if (typeof query !== 'undefined') {
                paginationQuery = Object.entries(query)
                    .filter(([k, v]) => k !== 'page' && v)
                    .map(([k, v]) => `${k}=${encodeURIComponent(v)}`)
                    .join('&');
            }
        %>
        <%- include('../../partials/pagination', { currentPage, totalPages, query: paginationQuery }) %>

        <!-- Create/Edit Offer Modal (Polished) -->
        <div x-show="showModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm px-4"
            style="display: none;" x-transition.opacity>
            <div class="bg-black-surface border border-white/10 w-full max-w-lg p-8 relative shadow-[0_0_50px_rgba(0,0,0,0.5)]"
                @click.away="closeModal()" x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="opacity-0 translate-y-8" x-transition:enter-end="opacity-100 translate-y-0">

                <div class="flex items-center gap-4 mb-8">
                    <button @click="closeModal()" type="button"
                        class="text-white hover:bg-accent hover:text-black transition-all border border-accent w-8 h-8 flex items-center justify-center rounded-sm bg-accent/5 shadow-[0_0_10px_rgba(255,106,0,0.2)] group">
                        <svg class="w-4 h-4 transform group-hover:rotate-90 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                    <h2 class="text-xl font-bold tracking-tight uppercase text-white"
                        x-text="isEditing ? 'Edit Offer' : 'Create Offer'"></h2>
                </div>

                <form @submit.prevent="submitForm()" data-no-spa="true" class="space-y-6">
                    <div class="grid grid-cols-2 gap-6">
                        <div class="col-span-2 space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Offer Name</label>
                            <input type="text" x-model="formData.name" @input="validateField('name')"
                                class="w-full bg-black border border-white/10 px-4 py-3 text-white text-xs focus:border-accent outline-none transition-all">
                            <p x-show="formErrors.name" class="text-status-danger text-[10px] mt-1" x-text="formErrors.name"></p>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Offer Type</label>
                            <select x-model="formData.type" class="w-full bg-black border border-white/10 px-4 py-3 text-white text-xs focus:border-accent outline-none">
                                <option value="Product">Product Specific</option>
                                <option value="Category">Category Wide</option>
                            </select>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Discount Type</label>
                            <select x-model="formData.discountType" class="w-full bg-black border border-white/10 px-4 py-3 text-white text-xs focus:border-accent outline-none">
                                <option value="percentage">Percentage (%)</option>
                                <option value="fixed">Fixed Amount (₹)</option>
                            </select>
                        </div>

                        <div class="space-y-1" x-show="formData.type === 'Product'">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Product</label>
                            <select x-model="formData.productId" @change="validateField('productId')"
                                class="w-full bg-black border border-white/10 px-4 py-3 text-white text-xs focus:border-accent outline-none">
                                <option value="">-- Select --</option>
                                <% products.forEach(p => { %> <option value="<%= p._id %>"><%= p.name %></option> <% }) %>
                            </select>
                            <p x-show="formErrors.productId" class="text-status-danger text-[10px] mt-1" x-text="formErrors.productId"></p>
                        </div>

                        <div class="space-y-1" x-show="formData.type === 'Category'">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Category</label>
                            <select x-model="formData.categoryId" @change="validateField('categoryId')"
                                class="w-full bg-black border border-white/10 px-4 py-3 text-white text-xs focus:border-accent outline-none">
                                <option value="">-- Select --</option>
                                <% categories.forEach(c => { %> <option value="<%= c._id %>"><%= c.name %></option> <% }) %>
                            </select>
                            <p x-show="formErrors.categoryId" class="text-status-danger text-[10px] mt-1" x-text="formErrors.categoryId"></p>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Discount Value</label>
                            <input type="number" x-model="formData.discountValue" @input="validateField('discountValue')"
                                class="w-full bg-black border border-white/10 px-4 py-3 text-white text-xs focus:border-accent outline-none transition-all">
                            <p x-show="formErrors.discountValue" class="text-status-danger text-[10px] mt-1" x-text="formErrors.discountValue"></p>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Start Date</label>
                            <input type="date" x-model="formData.startDate" @change="validateField('startDate')"
                                class="w-full bg-black border border-white/10 px-4 py-3 text-white text-xs focus:border-accent outline-none">
                            <p x-show="formErrors.startDate" class="text-status-danger text-[10px] mt-1" x-text="formErrors.startDate"></p>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Expiry Date</label>
                            <input type="date" x-model="formData.expiryDate" @change="validateField('expiryDate')"
                                class="w-full bg-black border border-white/10 px-4 py-3 text-white text-xs focus:border-accent outline-none">
                            <p x-show="formErrors.expiryDate" class="text-status-danger text-[10px] mt-1" x-text="formErrors.expiryDate"></p>
                        </div>
                    </div>

                    <div class="flex items-center gap-4 pt-6 border-t border-white/5">
                        <button type="button" @click="closeModal()" class="flex-1 py-4 border border-white/10 text-white text-[10px] font-bold tracking-widest uppercase">Cancel</button>
                        <button type="submit" :disabled="isSubmitting" class="flex-1 py-4 bg-accent text-black text-[10px] font-bold tracking-widest uppercase shadow-[0_0_20px_rgba(255,106,0,0.3)] hover:bg-white transition-all">
                            <span x-show="!isSubmitting">Save Offer</span>
                            <span x-show="isSubmitting">Processing...</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        (() => {
            const register = () => {
                if (Alpine.data('offerManager')) return;
                Alpine.data('offerManager', () => ({
                    showModal: false,
                    isEditing: false,
                    isSubmitting: false,
                    currentId: null,
                    currentTab: 'live',
                    search: '',
                    formData: { name: '', type: 'Product', discountType: 'percentage', discountValue: '', productId: '', categoryId: '', startDate: new Date().toISOString().split('T')[0], expiryDate: '' },
                    formErrors: { name: '', discountValue: '', productId: '', categoryId: '', startDate: '', expiryDate: '' },
                    openCreateModal() {
                        this.isEditing = false;
                        this.currentId = null;
                        this.formData = { name: '', type: 'Product', discountType: 'percentage', discountValue: '', productId: '', categoryId: '', startDate: new Date().toISOString().split('T')[0], expiryDate: '' };
                        this.formErrors = { name: '', discountValue: '', productId: '', categoryId: '', startDate: '', expiryDate: '' };
                        this.showModal = true;
                    },
                    async confirmDelete(id, name) {
                        const confirmed = await window.confirmAction({ 
                            title: 'DELETE OFFER?', 
                            message: `Are you sure you want to remove <span class='text-white font-black'>${name}</span>? This action is permanent and cannot be undone.`, 
                            type: 'error',
                            confirmText: 'Delete Permanently'
                        });
                        
                        if (confirmed) {
                            try {
                                const res = await fetch(`/admin/marketing/offers/delete/${id}`, { method: 'DELETE' });
                                const data = await res.json();
                                if (data.success) {
                                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Offer deleted successfully', type: 'success' } }));
                                    if (window.SpaNavigation) {
                                        setTimeout(() => window.SpaNavigation.loadPage(window.location.href), 800);
                                    } else {
                                        setTimeout(() => window.location.reload(), 800);
                                    }
                                } else {
                                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: data.message || 'Delete failed', type: 'error' } }));
                                }
                            } catch (err) {
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Network error occurred', type: 'error' } }));
                            }
                        }
                    },
                    openEditModal(id, name, type, dType, val, pId, cId, start, expiry) {
                        this.isEditing = true;
                        this.currentId = id;
                        this.formData = { name, type, discountType: dType, discountValue: val, productId: pId, categoryId: cId, startDate: start, expiryDate: expiry };
                        this.formErrors = { name: '', discountValue: '', productId: '', categoryId: '', startDate: '', expiryDate: '' };
                        this.showModal = true;
                    },
                    closeModal() { this.showModal = false; },
                    validateField(f) {
                        this.formErrors[f] = '';
                        if (f === 'name') {
                            if (!this.formData.name.trim()) this.formErrors.name = 'Offer name is required';
                            else if (this.formData.name.length < 3) this.formErrors.name = 'Name must be at least 3 characters';
                        }
                        if (f === 'discountValue') {
                            const val = parseFloat(this.formData.discountValue);
                            if (isNaN(val) || val <= 0) this.formErrors.discountValue = 'Value must be greater than 0';
                            else if (this.formData.discountType === 'percentage' && val > 100) this.formErrors.discountValue = 'Percentage cannot exceed 100%';
                        }
                        if (f === 'productId' && this.formData.type === 'Product') {
                            if (!this.formData.productId) this.formErrors.productId = 'Please select a product';
                        }
                        if (f === 'categoryId' && this.formData.type === 'Category') {
                            if (!this.formData.categoryId) this.formErrors.categoryId = 'Please select a category';
                        }
                        if (f === 'startDate') {
                            if (!this.formData.startDate) this.formErrors.startDate = 'Start date is required';
                        }
                        if (f === 'expiryDate') {
                            if (!this.formData.expiryDate) this.formErrors.expiryDate = 'Expiry date is required';
                            else if (this.formData.startDate && new Date(this.formData.expiryDate) <= new Date(this.formData.startDate)) {
                                this.formErrors.expiryDate = 'Expiry must be after start date';
                            }
                        }
                        return !this.formErrors[f];
                    },
                    validateAll() {
                        let isValid = true;
                        ['name', 'discountValue', 'productId', 'categoryId', 'startDate', 'expiryDate'].forEach(f => {
                            if (!this.validateField(f)) isValid = false;
                        });
                        return isValid;
                    },
                    async submitForm() {
                        if (!this.validateAll()) return;
                        this.isSubmitting = true;
                        try {
                            const res = await fetch(this.isEditing ? `/admin/marketing/offers/update/${this.currentId}` : '/admin/marketing/offers/create', {
                                method: this.isEditing ? 'PUT' : 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(this.formData)
                            });
                            const data = await res.json();
                            if (data.success) {
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Offer saved successfully!', type: 'success' } }));
                                if (window.SpaNavigation) {
                                    setTimeout(() => window.SpaNavigation.loadPage(window.location.href), 800);
                                } else {
                                    setTimeout(() => window.location.reload(), 800);
                                }
                            } else {
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: data.message, type: 'error' } }));
                            }
                        } catch (err) {
                            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Failed to save offer', type: 'error' } }));
                        } finally { this.isSubmitting = false; }
                    }
                }));
            };
            if (window.Alpine) register(); else document.addEventListener('alpine:init', register);
        })();
    </script>
