<!-- views/admin/analytics/salesReport.ejs -->
<%- contentFor('body') %>

<div class="space-y-10">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <h1 class="text-3xl font-bold tracking-tight uppercase text-white mb-2">SALES PROTOCOL.</h1>
            <p class="text-white/40 text-xs tracking-widest uppercase font-semibold">Analytical intelligence & revenue tracking</p>
        </div>
        
        <form id="filterForm" action="/admin/sales-report" method="GET" class="flex flex-wrap gap-4 items-end bg-black-surface border border-white/5 p-6 rounded-sm">
            <div class="space-y-2">
                <label class="text-[10px] font-bold text-white/30 uppercase tracking-widest">Reporting Period</label>
                <select name="filter" id="periodFilter" class="block w-full bg-black border border-white/10 text-white text-[11px] px-4 py-2 focus:border-accent outline-none transition-colors uppercase tracking-widest">
                    <option value="daily" <%= filter === 'daily' ? 'selected' : '' %>>Daily</option>
                    <option value="weekly" <%= filter === 'weekly' ? 'selected' : '' %>>Weekly</option>
                    <option value="yearly" <%= filter === 'yearly' ? 'selected' : '' %>>Yearly</option>
                    <option value="custom" <%= filter === 'custom' ? 'selected' : '' %>>Custom Range</option>
                </select>
            </div>

            <div id="customDateRange" class="<%= filter === 'custom' ? 'flex' : 'hidden' %> gap-4">
                <div class="space-y-2">
                    <label class="text-[10px] font-bold text-white/30 uppercase tracking-widest">Start Date</label>
                    <input type="date" name="startDate" value="<%= startDate %>" class="block bg-black border border-white/10 text-white text-[11px] px-4 py-2 focus:border-accent outline-none transition-colors">
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-bold text-white/30 uppercase tracking-widest">End Date</label>
                    <input type="date" name="endDate" value="<%= endDate %>" class="block bg-black border border-white/10 text-white text-[11px] px-4 py-2 focus:border-accent outline-none transition-colors">
                </div>
            </div>

            <button type="submit" class="px-6 py-2 bg-white text-black text-[11px] font-bold tracking-widest uppercase hover:bg-accent hover:text-white transition-all">Generate</button>
        </form>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-black-surface border border-white/5 p-8 group hover:border-white/10 transition-all relative overflow-hidden">
            <div class="absolute top-0 right-0 w-24 h-24 bg-accent/5 rounded-full -mr-12 -mt-12 group-hover:bg-accent/10 transition-colors"></div>
            <h4 class="text-white/30 text-[10px] font-bold tracking-[0.2em] uppercase mb-6">Total Sales Count</h4>
            <span class="text-4xl font-mono font-bold text-white"><%= stats.totalSales %></span>
            <p class="text-white/20 text-[10px] mt-2 font-bold uppercase tracking-widest">Successful Transactions</p>
        </div>

        <div class="bg-black-surface border border-white/5 p-8 group hover:border-white/10 transition-all relative overflow-hidden">
            <div class="absolute top-0 right-0 w-24 h-24 bg-status-success/5 rounded-full -mr-12 -mt-12 group-hover:bg-status-success/10 transition-colors"></div>
            <h4 class="text-white/30 text-[10px] font-bold tracking-[0.2em] uppercase mb-6">Total Revenue</h4>
            <span class="text-4xl font-mono font-bold text-white">₹<%= stats.totalRevenue.toLocaleString() %></span>
            <p class="text-status-success text-[10px] mt-2 font-bold uppercase tracking-widest">Gross Sales Amount</p>
        </div>

        <div class="bg-black-surface border border-white/5 p-8 group hover:border-white/10 transition-all relative overflow-hidden">
            <div class="absolute top-0 right-0 w-24 h-24 bg-status-danger/5 rounded-full -mr-12 -mt-12 group-hover:bg-status-danger/10 transition-colors"></div>
            <h4 class="text-white/30 text-[10px] font-bold tracking-[0.2em] uppercase mb-6">Total Discounts</h4>
            <span class="text-4xl font-mono font-bold text-white">₹<%= stats.totalDiscount.toLocaleString() %></span>
            <p class="text-status-danger text-[10px] mt-2 font-bold uppercase tracking-widest">Promotional Deductions</p>
        </div>
    </div>

    <!-- Export Actions -->
    <div class="flex justify-end gap-4">
        <a href="/admin/sales-report/download?filter=<%= filter %>&startDate=<%= startDate %>&endDate=<%= endDate %>&format=pdf" 
           target="_blank"
           class="flex items-center gap-2 px-6 py-3 bg-white/5 border border-white/10 text-white text-[11px] font-bold tracking-widest uppercase hover:bg-white/10 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            Export PDF
        </a>
        <a href="/admin/sales-report/download?filter=<%= filter %>&startDate=<%= startDate %>&endDate=<%= endDate %>&format=excel" 
           target="_blank"
           class="flex items-center gap-2 px-6 py-3 bg-white/5 border border-white/10 text-white text-[11px] font-bold tracking-widest uppercase hover:bg-white/10 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            Export Excel
        </a>
        <a href="/admin/sales-report/download?filter=<%= filter %>&startDate=<%= startDate %>&endDate=<%= endDate %>&format=ledger" 
           target="_blank"
           class="flex items-center gap-2 px-6 py-3 bg-accent text-black text-[11px] font-bold tracking-widest uppercase hover:bg-white transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            Export Ledger
        </a>
    </div>

    <!-- Orders Table -->
    <div class="bg-black-surface border border-white/5 overflow-hidden">
        <h3 class="text-white text-[11px] font-bold tracking-widest uppercase px-10 py-8 border-b border-white/5">Detailed Transaction Log</h3>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-white/[0.02]">
                        <th class="px-10 py-6 text-[10px] font-bold text-white/30 uppercase tracking-widest">Order ID</th>
                        <th class="px-10 py-6 text-[10px] font-bold text-white/30 uppercase tracking-widest">Date</th>
                        <th class="px-10 py-6 text-[10px] font-bold text-white/30 uppercase tracking-widest">Customer</th>
                        <th class="px-10 py-6 text-[10px] font-bold text-white/30 uppercase tracking-widest text-right">Amount</th>
                        <th class="px-10 py-6 text-[10px] font-bold text-white/30 uppercase tracking-widest text-right">Discount</th>
                        <th class="px-10 py-6 text-[10px] font-bold text-white/30 uppercase tracking-widest text-center">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <% if (orders.length > 0) { %>
                        <% orders.forEach(order => { %>
                            <tr class="hover:bg-white/[0.02] transition-colors group">
                                <td class="px-10 py-6 text-xs font-mono text-white/60">#<%= order.orderId %></td>
                                <td class="px-10 py-6 text-xs text-white/60"><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></td>
                                <td class="px-10 py-6">
                                    <div class="flex flex-col">
                                        <span class="text-xs font-bold text-white uppercase"><%= order.user ? order.user.firstName + ' ' + order.user.lastName : 'Deleted User' %></span>
                                        <span class="text-[10px] text-white/30"><%= order.user ? order.user.email : '' %></span>
                                    </div>
                                </td>
                                <td class="px-10 py-6 text-xs font-bold text-white text-right">₹<%= order.totalAmount.toLocaleString() %></td>
                                <td class="px-10 py-6 text-xs text-status-danger text-right">-₹<%= order.discount.toLocaleString() %></td>
                                <td class="px-10 py-6 text-center">
                                    <span class="px-3 py-1 bg-status-success/10 text-status-success text-[9px] font-bold uppercase tracking-widest border border-status-success/20">
                                        <%= order.orderStatus %>
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="px-10 py-20 text-center text-white/20 text-xs uppercase tracking-widest">No transaction data available for this period.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.getElementById('periodFilter').addEventListener('change', function() {
        const customDateRange = document.getElementById('customDateRange');
        if (this.value === 'custom') {
            customDateRange.classList.remove('hidden');
            customDateRange.classList.add('flex');
        } else {
            customDateRange.classList.add('hidden');
            customDateRange.classList.remove('flex');
        }
    });
</script>
